/*
 * interpreter/tests/tests_interfaces.rxas
 */

.meta "interface_factory_tiebreak.car"="b" ".unknown" .class
.meta "interface_factory_tiebreak.car"="interface_factory_tiebreak.vehicle" .implements
.meta "interface_factory_tiebreak.car._name"="b" ".string" .attr 1
.meta "interface_factory_tiebreak.truck"="b" ".unknown" .class
.meta "interface_factory_tiebreak.truck"="interface_factory_tiebreak.vehicle" .implements
.meta "interface_factory_tiebreak.truck._name"="b" ".string" .attr 1
.meta "interface_factory_tiebreak.vehicle"="b" ".unknown" .interface
.meta "interface_factory_tiebreak.vehicle"="method" "describe" ".string" "" .member
.meta "interface_factory_tiebreak.vehicle"="factory" "*" ".vehicle" "name=.string" .member
.meta "interface_factory_tiebreak.vehicle"="factory" "from_name" ".vehicle" "name=.string" .member
.meta "interface_default_vm.box"="b" ".unknown" .class
.meta "interface_default_vm.box"="interface_default_vm.shape" .implements
.meta "interface_default_vm.shape"="b" ".unknown" .interface
.meta "interface_default_vm.shape"="method final" "describe" ".string" "" .member
.meta "interface_default_vm.shape"="method final" "prefix" ".string" "" .member
.meta "interface_default_vm.shape"="method" "summary" ".string" "" .member
.meta "interface_default_vm.shape"="factory" "*" ".shape" "" .member

.globals=0

main() .locals=10
   say "Test Suite: Interface Factory Dispatch"

   load r1,58
   metadecodeinst r2,r1
   linkattr r3,r2,1
   seq r4,r3,"SRCFPROC_REG_STRING_REG"
   brf fail_opcode_name,r4
   linkattr r3,r2,3
   ieq r4,r3,3
   brf fail_opcode_arity,r4

   load r1,1
   load r2,"duo"
   settp r2,3
   srcfproc r0,"interface_factory_tiebreak.vehicle",r1
   dcall r0,r0,r1

   load r1,1
   settp r0,1
   swap r2,r0
   srcmethod r3,r2,"describe"
   dcall r3,r3,r1
   swap r0,r2
   seq r4,r3,"car:duo"
   brf fail_tiebreak,r4

   load r1,1
   load r2,"duo"
   settp r2,3
   srcfproc r0,"interface_factory_tiebreak.vehicle..from_name",r1
   dcall r0,r0,r1

   load r1,1
   settp r0,1
   swap r2,r0
   srcmethod r3,r2,"describe"
   dcall r3,r3,r1
   swap r0,r2
   seq r4,r3,"truck:truck:named:duo"
   brf fail_named_tiebreak,r4

   load r1,0
   srcfproc r0,"interface_default_vm.shape",r1
   dcall r0,r0,r1

   load r1,1
   settp r0,1
   swap r2,r0
   srcmethod r3,r2,"describe"
   dcall r3,r3,r1
   swap r0,r2
   seq r4,r3,"iface:box"
   brf fail_default_method,r4

   typeof r5,r0
   seq r4,r5,".interface_default_vm..box"
   brf fail_typeof,r4

   istype r5,r0,".interface_default_vm..shape"
   ieq r4,r5,1
   brf fail_istype_interface,r4

   istype r5,r0,"interface_default_vm.box"
   ieq r4,r5,1
   brf fail_istype_class,r4

   asserttype r0,".interface_default_vm..shape"

   say "PASS: Interface Dispatch Suite"
   ret 0

fail_opcode_name:
   say "FAIL: METADECODEINST SRCFPROC Name"
   ret 0

fail_opcode_arity:
   say "FAIL: METADECODEINST SRCFPROC Operand Count"
   ret 0

fail_tiebreak:
   say "FAIL: SRCFPROC Tie-Break"
   say r3
   ret 0

fail_named_tiebreak:
   say "FAIL: SRCFPROC Named Tie-Break"
   say r3
   ret 0

fail_default_method:
   say "FAIL: SRCMETHOD Default Body"
   say r3
   ret 0

fail_typeof:
   say "FAIL: TYPEOF Concrete Type"
   say r5
   ret 0

fail_istype_interface:
   say "FAIL: ISTYPE Interface"
   say r5
   ret 0

fail_istype_class:
   say "FAIL: ISTYPE Class"
   say r5
   ret 0

