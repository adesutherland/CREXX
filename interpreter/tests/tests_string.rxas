/*
 * interpreter/tests/tests_string.rxas
 */

.globals=0

main() .locals=15
    say "Test Suite: Strings"

    /* CONCAT */
    load r1, "Hello"
    load r2, "World"
    concat r3, r1, r2
    seq r0, r3, "HelloWorld"
    brt concat_pass, r0
    say "FAIL: CONCAT"
    br concat_end
concat_pass:
    say "PASS: CONCAT"
concat_end:

    /* SCONCAT */
    load r1, "Hello"
    load r2, "World"
    sconcat r3, r1, r2
    seq r0, r3, "Hello World"
    brt sconcat_pass, r0
    say "FAIL: SCONCAT"
    br sconcat_end
sconcat_pass:
    say "PASS: SCONCAT"
sconcat_end:

    /* APPEND */
    load r1, "Hello"
    load r2, "World"
    append r1, r2
    seq r0, r1, "HelloWorld"
    brt append_pass, r0
    say "FAIL: APPEND"
    br append_end
append_pass:
    say "PASS: APPEND"
append_end:

    /* SAPPEND */
    load r1, "Hello"
    load r2, "World"
    sappend r1, r2
    seq r0, r1, "Hello World"
    brt sappend_pass, r0
    say "FAIL: SAPPEND"
    br sappend_end
sappend_pass:
    say "PASS: SAPPEND"
sappend_end:

    /* APPENDCHAR */
    load r1, "ABC"
    load r2, 68 /* 'D' */
    appendchar r1, r2
    seq r0, r1, "ABCD"
    brt appendchar_pass, r0
    say "FAIL: APPENDCHAR"
    br appendchar_end
appendchar_pass:
    say "PASS: APPENDCHAR"
appendchar_end:

    /* STRLEN */
    load r1, "Testing"
    strlen r2, r1
    ieq r0, r2, 7
    brt strlen_pass, r0
    say "FAIL: STRLEN"
    br strlen_end
strlen_pass:
    say "PASS: STRLEN"
strlen_end:

    /* SUBSTR - using SETSTRPOS */
    load r1, "Hello World"
    load r2, 6 /* 0-based character offset for 'W' */
    setstrpos r1, r2
    load r3, 5 /* Length */
    substr r4, r1, r3
    seq r0, r4, "World"
    brt substr_pass, r0
    say "FAIL: SUBSTR"
    br substr_end
	substr_pass:
	    say "PASS: SUBSTR"
	substr_end:

	    /* SCOPY must copy logical string contents with a reset cursor. */
	    load r1, "Hello World"
	    load r2, 6
	    setstrpos r1, r2
	    scopy r4, r1
	    getstrpos r5, r4
	    ieq r0, r5, 0
	    brt scopy_cursor_pass, r0
	    say "FAIL: SCOPY cursor reset"
	    br scopy_cursor_end
	scopy_cursor_pass:
	    say "PASS: SCOPY cursor reset"
	scopy_cursor_end:

	    /* UTF8 SUBSTR regression: one codepoint substring must keep correct char count. */
	    load r1, "🔥fire"
    load r2, 0
    setstrpos r1, r2
    load r3, 1
    substr r4, r1, r3
    load r5, ""
    strlen r7, r4
    ieq r0, r7, 1
    brf utf_substr_fail, r0

    load r6, 0
    hexchar r5, r4, r6
    seq r0, r5, "25"
    brf utf_substr_fail, r0

    load r6, 1
    hexchar r5, r4, r6
    seq r0, r5, "00"
    brf utf_substr_fail, r0

    load r6, 2
    hexchar r5, r4, r6
    seq r0, r5, "00"
    brf utf_substr_fail, r0

    load r6, 3
    hexchar r5, r4, r6
    seq r0, r5, "00"
    brf utf_substr_fail, r0

    /* UTF8 SUBSTR from an interior cursor must use codepoint lengths, not byte lengths. */
    load r1, "A🔥éZ"
    load r2, 1
    setstrpos r1, r2
    load r3, 2
    substr r4, r1, r3
    seq r0, r4, "🔥é"
    brf utf_substr_fail, r0
    strlen r7, r4
    ieq r0, r7, 2
    brf utf_substr_fail, r0

    /* Same-register SUBSTR must remain safe. */
    load r1, "A🔥éZ"
    load r2, 1
    setstrpos r1, r2
    load r3, 2
    substr r1, r1, r3
    seq r0, r1, "🔥é"
    brf utf_substr_fail, r0
    strlen r7, r1
    ieq r0, r7, 2
    brf utf_substr_fail, r0

    /* Length is clipped to remaining codepoints from the current cursor. */
    load r1, "A🔥éZ"
    load r2, 2
    setstrpos r1, r2
    load r3, 9
    substr r4, r1, r3
    seq r0, r4, "éZ"
    brf utf_substr_fail, r0
    strlen r7, r4
    ieq r0, r7, 2
    brf utf_substr_fail, r0

    load r1, "🔥fire"
    load r2, 1
    substcut r1, r2
    strlen r7, r1
    ieq r0, r7, 1
    brf utf_substr_fail, r0

    load r1, "A🔥éZ"
    load r2, 3
    substcut r1, r2
    seq r0, r1, "A🔥é"
    brf utf_substr_fail, r0
    strlen r7, r1
    ieq r0, r7, 3
    brf utf_substr_fail, r0

    say "PASS: UTF substring metadata"
    br utf_hexchar_end
utf_substr_fail:
    say "FAIL: UTF substring metadata"
utf_hexchar_end:

    /* TRIML (3-reg) - Trims the character specified in R3 */
    load r1, "   TrimMe"
    load r2, " "
    triml r3, r1, r2
    seq r0, r3, "TrimMe"
    brt triml_pass, r0
    say "FAIL: TRIML"
    br triml_end
triml_pass:
    say "PASS: TRIML"
triml_end:

    /* TRIMR (3-reg) */
    load r1, "TrimMe!!!"
    load r2, "!"
    trimr r3, r1, r2
    seq r0, r3, "TrimMe"
    brt trimr_pass, r0
    say "FAIL: TRIMR"
    br trimr_end
trimr_pass:
    say "PASS: TRIMR"
trimr_end:

    /* STRLOWER */
    load r1, "MIXED Case"
    strlower r2, r1
    seq r0, r2, "mixed case"
    brt strlower_pass, r0
    say "FAIL: STRLOWER"
    br strlower_end
strlower_pass:
    say "PASS: STRLOWER"
strlower_end:

    /* STRUPPER */
    load r1, "mixed case"
    strupper r2, r1
    seq r0, r2, "MIXED CASE"
    brt strupper_pass, r0
    say "FAIL: STRUPPER"
    br strupper_end
strupper_pass:
    say "PASS: STRUPPER"
strupper_end:

    /* STRPOS - R1 is start pos (1-based) AND result */
    load r1, 1 /* start at pos 1 */
    load r2, "World"
    load r3, "Hello World"
    strpos r1, r2, r3
    ieq r0, r1, 7
    brt strpos_pass, r0
    say "FAIL: STRPOS"
    br strpos_end
strpos_pass:
    say "PASS: STRPOS"
strpos_end:

    /* UTF STRPOS - start/result must be codepoint based, not byte based. */
    load r1, 3 /* start at codepoint 3 */
    load r2, "→"
    load r3, "a→b→c"
    strpos r1, r2, r3
    ieq r0, r1, 4
    brt strpos_utf_pass, r0
    say "FAIL: UTF STRPOS"
    br strpos_utf_end
strpos_utf_pass:
    say "PASS: UTF STRPOS"
strpos_utf_end:

    /* FNDBLNK - R1 result, R2 string, R3 start (0-based) */
    load r2, "One Two Three"
    load r3, 0
    fndblnk r1, r2, r3
    ieq r0, r1, 3
    brt fndblnk_pass, r0
    say "FAIL: FNDBLNK"
    br fndblnk_end
fndblnk_pass:
    say "PASS: FNDBLNK"
fndblnk_end:

    /* Robustness: Whitespace-only strings */
    load r1, "   "
    load r2, " "
    triml r3, r1, r2
    seq r0, r3, ""
    brt trim_ws_pass, r0
    say "FAIL: Trim whitespace-only"
    br trim_ws_end
trim_ws_pass:
    say "PASS: Trim whitespace-only"
trim_ws_end:

    ret 0
