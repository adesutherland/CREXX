import system
##cflags def nset  3buf  parse def
##  array=.string[]

myint=7
Select
  when myint=1 then do
    say "value is 1"
    say "End of when"
    leave
  end
    when myint=2 | myint<8 then say "value is between 2 and 7"
  when myint=3 then say "value is 3"
  when myint=4 then say "value is 4"
  when myint=5 then say "value is 5"
  otherwise say 'Integer out of range'
end /* End of Select */


City='Vienna'
Select
  when city='Munich' | city='Vienna' then say "our Language is Bairisch"
  when city='London' then say "value is London"
  when city='Vienna' then say "value is Vienna"
  when city='Paris'  then say "value is Paris"
  otherwise say 'unknown city'
end /* End of Select */

City='Munich'
var1='Berlin'
Switch city
 case var1 then say "switch label is a variable"
  case 'Munich' then say "value is Munich"
  case 'London' then say "value is London"
  case 'Vienna' then say "value is Vienna"
  case 'Paris'  then say "value is Paris"
  default say 'unknown city'
end /* End of Select */


exit
