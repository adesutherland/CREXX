options levelb
import rxfnsb
import process

##cflags def nset  3buf  nparse

##global int passed,failed

/* testpipe.rex — CREXX Level-b test harness for your PIPE engine
   Run:  rexx testpipe.rex
   Note: expects your `pipe` procedure to be available (same file or imported)
*/

/* ===== config ===== */
base = 'C:\temp\PipeTest'
call ensureDir base

/* ===== main ===== */
passed = 0
failed = 0

say '=== Preparing sample data...'
call makeSampleFiles base

say '=== Running tests...'

/* ---- COUNT ---- */
call runTest 'count records', ,
  '< "'base'\sample.txt" | COUNT | > "'base'\count.txt"', ,
  'expectFileLinesEq', "'"base"\count.txt'", '5'

/* ---- Core I/O ---- */
call runTest 'copy file', '< "'base'\sample.txt" | > "'base'\copy.txt"', ,
  'expectLineCount', "'"base"\copy.txt'", 5

/* ---- LOCATE ---- */
call runTest 'locate red', ,
  '< "'base'\sample.txt" | LOCATE "red" | > "'base'\only_red.txt"', ,
  'expectFileLinesEq', "'"base"\only_red.txt'", 'apple red|cherry red'

/* ---- CHANGE ---- */
call runTest 'change banana->pear', ,
  '< "'base'\sample.txt" | CHANGE "banana" "pear" | > "'base'\changed.txt"',  ,
  'expectContainsAll', "'"base"\changed.txt'", 'pear yellow|pear green'

/* ---- SPECS ---- */
call runTest 'specs 1-6', ,
  '< "'base'\sample.txt" | SPECS 1-6 | > "'base'\first6.txt"', ,
  'expectFileLinesEq', "'"base"\first6.txt'", 'apple |banana|cherry|orange|banana'

/* ---- DROP ---- */
call runTest 'drop 2', ,
  '< "'base'\sample.txt" | DROP 2 | > "'base'\dropped2.txt"', ,
  'expectLineStartsWith', "'"base"\dropped2.txt'", 'cherry red'

/* ---- TAKE ---- */
call runTest 'take 3', ,
  '< "'base'\sample.txt" | TAKE 3 | > "'base'\take3.txt"', ,
  'expectLineCount', "'"base"\take3.txt'", 3

/* ---- FIELD (whitespace) ---- */
call runTest 'field 2 -> colors', ,
  '< "'base'\sample.txt" | FIELD 2 | > "'base'\colors.txt"', ,
  'expectFileLinesEq', "'"base"\colors.txt'", 'red|yellow|red|orange|green'

/* ---- UNIQUE ---- */
call runTest 'unique colors', ,
  '< "'base'\sample.txt" | FIELD 2 | UNIQUE | > "'base'\unique_colors.txt"', ,
  'expectSetEq', "'"base"\unique_colors.txt'", 'red|yellow|orange|green'

/* ---- UPPER/LOWER ---- */
call runTest 'upper', ,
  '< "'base'\sample.txt" | UPPER | > "'base'\upper.txt"', ,
  'expectContainsAll', "'"base"\upper.txt'", 'APPLE RED|BANANA YELLOW'

call runTest 'lower', ,
  '< "'base'\sample.txt" | LOWER | > "'base'\lower.txt"', ,
  'expectContainsAll', "'"base"\lower.txt'", 'banana green|orange orange'

/* ---- TRIM ---- */
call runTest 'trim both', ,
  '< "'base'\padded.txt" | TRIM | > "'base'\trim_both.txt"', ,
  'expectNoLeadingTrailingSpaces', "'"base"\trim_both.txt'"

/* ---- PAD ---- */
call runTest 'pad 12 RIGHT', ,
  '< "'base'\sample.txt" | FIELD 1 | PAD 12 RIGHT | > "'base'\padR12.txt"', ,
  'expectMinWidth', "'"base"\padR12.txt'", 12

/* ---- FIELD with SEP on CSV ---- */
call runTest 'field 2 SEP "," from csv', ,
  '< "'base'\csv.txt" | FIELD 2 SEP "," | > "'base'\csv_col2.txt"', ,
  'expectFileLinesEq', "'"base"\csv_col2.txt'", 'name|apple|banana|cherry|orange|banana'

/* ---- SORT (alias to CMD sort) ---- */
call runTest 'sort ascending', ,
  '< "'base'\sample.txt" | SORT | > "'base'\sorted.txt"', ,
  'expectSortedAscending', "'"base"\sorted.txt'"

/* ---- SORT + UNIQUE chain on CSV col2 ---- */
call runTest 'csv col2 unique sorted',  ,
  '< "'base'\csv.txt" | FIELD 2 SEP "," | UNIQUE | SORT | > "'base'\names_unique_sorted.txt"',  ,
  'expectFileLinesEq', "'"base"\names_unique_sorted.txt'", 'apple|banana|cherry|name|orange'

/* ---- CMD SYNC + TIMEOUT (sort) ---- */
call runTest 'cmd sort SYNC timeout',  ,
  '< "'base'\sample.txt" | CMD "sort" SYNC TIMEOUT=5000 | > "'base'\sorted_sync.txt"', ,
  'expectFilesEqual', "'"base"\sorted_sync.txt'", "'"base"\sorted.txt'"

/* ---- DROP beyond size ---- */
call runTest 'drop 9999 -> empty',  ,
  '< "'base'\sample.txt" | DROP 9999 | > "'base'\drop_all.txt"', ,
  'expectLineCount', "'"base"\drop_all.txt'", 0

/* ---- LOCATE none + COUNT -> zero ---- */
call runTest 'locate none + count', ,
  '< "'base'\sample.txt" | LOCATE "NO_MATCH" | COUNT | > "'base'\zero.txt"', ,
  'expectFileLinesEq', "'"base"\zero.txt'", '0'

/* ---- DONE ---- */
say ''
say '=== TEST SUMMARY ==='
say 'Passed:' passed '  Failed:' failed
if failed > 0 then exit 1
exit 0

/* ================= helpers ================= */

runTest: procedure
  arg name=.string, cmd=.string, checkProc=.string, p1=.string, p2=''
  say Copies('-',72)
  say '   Action 'name
  say '   Test   'checkProc
  call pipe cmd
  rc = 0
  if checkProc='expectLineCount'  then rc=expectLineCount(p1,p2)
  else if checkProc='expectFileLinesEq'  then  rc=expectFileLinesEq(p1,p2)
  else if checkProc='expectContainsAll' then  rc=expectContainsAll(p1,p2)
  else if checkProc='expectLineStartsWith' then  rc=expectLineStartsWith(p1,p2)
  else if checkProc='expectSetEq' then  rc=expectSetEq(p1,p2)
  else if checkProc='expectNoLeadingTrailingSpaces' then  rc=expectNoLeadingTrailingSpaces(p1,p2)
  else if checkProc='expectMinWidth' then  rc=expectMinWidth(p1,p2)
  else if checkProc='expectSortedAscending' then rc=expectSortedAscending(p1,p2)

  if rc = 0 then do
    passed = passed + 1
    say '   Result -- OK: 'name
  end
  else do
    failed = failed + 1
    say '   Result +++ FAIL: 'name ' (rc='rc')'
  end
  say Copies('=',72)
  say ' '
  return

ensureDir: procedure
  arg dir=.string
/*
  /* Windows: ensure C:\temp exists; else create via CMD */
  if stream(dir, 'C', 'QUERY EXISTS') = '' then do
    address cmd 'mkdir "'dir'" >NUL 2>&1'
  end
 */
  return

makeSampleFiles: procedure
  arg base=.string
  /* sample.txt */
  s = .string[]
  s[1]='apple red'
  s[2]='banana yellow'
  s[3]='cherry red'
  s[4]='orange orange'
  s[5]='banana green'
  ExecIO * DISKW base'\sample.txt' stem s

  /* padded.txt */
  p = .string[]
  p[1]='    apple  '
  p[2]='  banana     '
  p[3]='   cherry'
  p[4]='orange'
  ExecIO * DISKW base'\padded.txt' stem p

  /* csv.txt */
  c = .string[]
  c[1]='id,name,color'
  c[2]='1,apple,red'
  c[3]='2,banana,yellow'
  c[4]='3,cherry,red'
  c[5]='4,orange,orange'
  c[6]='5,banana,green'
  ExecIO * DISKW base'\csv.txt' stem c

  /* dupes.txt */
  d = .string[]
  d[1]='A'
  d[2]='B'
  d[3]='A'
  d[4]='C'
  d[5]='B'
  d[6]='D'
  ExecIO * DISKW base'\dupes.txt' stem d
  return

/* ===== assertion helpers (return 0 on success, nonzero on fail) ===== */

expectLineCount: procedure=.int
  arg fn=.string, want=.string
  a = readAll(fn)
  if a[0] = want then return 0
  say 'Expected' want 'lines, got' a[0]
  return 1

expectFilesEqual: procedure=.int
  arg fn1=.string, fn2=.string
  a = readAll(fn1)
  b = readAll(fn2)
  if a[0] \= b[0] then do
    say 'Different line counts:' a[0] 'vs' b[0]
        say "+++ Result Array "
        call writeSink_CONSOLE a
        say "+++ Wanted Array"
        call writeSink_CONSOLE b
    return 2
  end
  do i=1 to a[0]
    if a[i] \= b[i] then do
      say 'First diff at line' i':' a[i] '!=' b[i]
      say "+++ Result Array "
      call writeSink_CONSOLE a
      say "+++ Wanted Array"
      call writeSink_CONSOLE b
      return 3
    end
  end
  return 0

expectFileLinesEq: procedure=.int
  /* wantLines: 'line1|line2|...' (exact match order) */
  arg fn=.string, wantLines=.string
  a = readAll(fn)
  w = splitPipe(wantLines)

  if a[0] \= w[0] then do
    say '+++ Expected' w[0] 'lines, got' a[0]
    say "+++ Result Array "fn
    call writeSink_CONSOLE a
    say "+++ Wanted Array"
    call writeSink_CONSOLE w
    return 4
  end
  do i=1 to w[0]
    if strip(a[i]) \= strip(w[i]) then do
      say 'Mismatch at line' i': "'a[i]'" != "'w[i]'" '
      return 5
    end
  end
  return 0

expectContainsAll: procedure=.int
  /* require each token to appear in some line */
  arg fn=.string, tokens=.string
  a = readAll(fn)
  t = splitPipe(tokens)
  do i=1 to t[0]
    found = 0
    do k=1 to a[0]
       if pos(t[i], a[k])=0 then iterate;
       found=1
       leave
    end
    if found=0 then do
      say 'Token not found:' t[i]
      return 6
    end
  end
  return 0

expectLineStartsWith: procedure=.int
  arg fn=.string, prefix=.string
  a = readAll(fn)
  if a[0] = 0 then do; say 'Empty file'; return 7; end
  if left(a[1], length(prefix)) = prefix then return 0
  say 'First line does not start with "'prefix'":' a[1]
  return 8

expectNoLeadingTrailingSpaces: procedure=.int
  arg fn=.string,dummy=''
  a = readAll(fn)
  do i=1 to a[0]
    if left(a[i],1)=' ' | right(a[i],1)=' ' then do
      say 'Line has edge spaces:' a[i]
      return 9
    end
  end
  return 0

expectMinWidth: procedure=.int
  arg fn=.string, w=.string
  a = readAll(fn)
  do i=1 to a[0]
    if length(a[i]) < w then do
      say 'Line' i 'shorter than' w':' a[i]
      return 10
    end
  end
  return 0

expectSortedAscending: procedure=.int
  arg fn=.string,dummy=''
  a = readAll(fn)
  do i=2 to a[0]
    if a[i-1] > a[i] then do
      say 'Not sorted at line' i-1 '>' i':' a[i-1] '>' a[i]
      return 11
    end
  end
  return 0

expectSetEq: procedure=.int
  /* order-insensitive equality with expected set in 'a|b|c' format */
  arg fn=.string, want=.string
  a = readAll(fn)
  w = splitPipe(want)
  if a[0] \= w[0] then do
     say 'Different set sizes:' a[0] 'vs' w[0]
     say "+++ Result Array "fn
     call writeSink_CONSOLE a
     say "+++ Wanted Array"
     call writeSink_CONSOLE w
     return 12
  end
  do i=1 to w[0]
     found=0
     do j=1 to a[0]
        if a[j]\=w[i] then iterate
        found=1
     end
     if found=0 then do
        say 'Missing expected item:' w[i]
        return 13
     end
  end
  return 0

/* ===== small utilities ===== */

readAll: procedure=.string[]
  arg fn=.string
  r = .string[]
  fn=unquote(fn)
  ExecIO * DISKR fn stem r
return r
  empty=0
  do j=r.0 to 1 by -1
     blk=Countstr(' ',r[j])
 ## todo it seems we have a glitch in strip

     if strip(temp)='' | blk=length(r[j]) then do
        empty=empty+1
     end
     else leave
  end
  if empty=0 then return r
  q=.string[]
  do j=1 to r[0]-empty
     q[j]=r[j]
  end
return q

splitPipe: procedure=.string[]
  arg s=.string
  out = .string[]
  if s = '' then return out
  p = 1
  do forever
    q = pos('|', s, p)
    if q = 0 then do
      out[out[0]+1] = strip(substr(s, p))
      leave
    end
    out[out[0]+1] = strip(substr(s, p, q-p))
    p = q + 1
  end
return out





/*
/* pipe.rex — Minimal CMS-Pipelines-like runner for Regina
   Example:
*/
     call pipe  '< "C:\temp\sample.txt" | sort /r | console | > "C:\temp\sort1.txt" '
     call pipe '< "C:\temp\sample.txt"  | locate "banana" |console| > "C:\temp\locate.txt"'
     call pipe '< "C:\temp\sample.txt"  | take 2 |console| > "C:\temp\take.txt"'
     call pipe '< "C:\temp\sample.txt" | field 1 | pad 12 RIGHT | console | > "C:\temp\pad.txt"'
/*  pipe
say '*****'
     call pipe  '< "C:\temp\testrx2.txt" | specs 1-20 | CMD "sort" | > "C:\temp\testrx4.txt"'
*/
exit
*/
pipe: procedure
arg pipeline=.string
if pipeline = '' then do
  say 'Usage:'
  say '  PIPE < in.txt | locate "ERROR" | change "ERROR" "WARN" | > out.txt'
  say '  PIPE < data.txt | specs 1-20 | CMD "sort" | > top20.txt'
  exit 0
end

/* ---------- Parse pipeline into stages (plain Regina) ---------- */
stage=splitStages(pipeline)
if stage.0 = 0 then do
   say 'No stages'
   exit 8
end
say "   Stage  "pipeline

/* Run it */
call runPipeline stage

return

/* ===== helpers ===== */

splitStages: procedure=.string[]
  /* splits on | but honors quoted strings */
  arg text=.string
  stem=.string[]
  q = 0; tok = ''; n = 0
  do i = 1 to length(text)
    c = substr(text,i,1)
    if c = '"' then q = \q
    if c = '|' & \q then do
      if strip(tok) \= '' then do
         n = n+1
         stem[n] = strip(tok)
      end
      tok = ''
    end
    else tok = tok || c
  end
  if strip(tok) \= '' then do
     n = n+1
     stem[n] = strip(tok)
  end
return stem

getStageType: procedure=.string
  arg s=.string
  s2 = strip(s)
  sU = translate(s2)

  /* --- Sources & Sinks --- */
  if left(s2,1) = '<' then return 'READ'
  if left(s2,1) = '>' then return 'WRITE'
  if left(sU,7) = 'CONSOLE' then return 'CONSOLE'
  if left(sU,4) = 'NULL' then return 'NULL'

  /* --- Core Filters --- */
  if left(sU,6) = 'LOCATE' then return 'LOCATE'
  if left(sU,6) = 'CHANGE' then return 'CHANGE'
  if left(sU,5) = 'SPECS'  then return 'SPECS'
  if left(sU,4) = 'DROP'   then return 'DROP'
  if left(sU,4) = 'TAKE'   then return 'TAKE'
  if left(sU,5) = 'COUNT'  then return 'COUNT'
  if left(sU,5) = 'TRACE'  then return 'TRACE'
  if left(sU,4) = 'SORT'   then return 'SORT'
  if left(sU,6) = 'UNIQUE' then return 'UNIQUE'
  if left(sU,5) = 'FIELD'  then return 'FIELD'
  if left(sU,5) = 'UPPER'  then return 'UPPER'
  if left(sU,5) = 'LOWER'  then return 'LOWER'
  if left(sU,4) = 'TRIM'   then return 'TRIM'
  if left(sU,3) = 'PAD'    then return 'PAD'
  if left(sU,4) = 'TIME'   then return 'TIME'
  /* --- Command Stage --- */
  if left(sU,3) = 'CMD'    then return 'CMD'

  /* --- Default fallback --- */
  return 'CMD'


unquote: procedure=.string
  arg s=.string
  s = strip(s)
  if left(s,1)='"' & right(s,1)='"' then return substr(s,2,length(s)-2)
  if left(s,1)="'" & right(s,1)="'" then return substr(s,2,length(s)-2)
return s

/* ---------- core runner ---------- */
runPipeline: procedure
  arg stages=.string[]

  /* ---- SOURCE ---- */
  if stages[0] < 1 then do
    say 'No stages given'
    return
  end

  s1 = stages[1]
  t1 = getStageType(s1)

  if t1 = 'READ' then     lines = readSource_FILE(s1)
  else if t1 = 'CMD' then lines = readSource_CMD(s1)
  else do
    say 'First stage must be "< file" or CMD "..."'
    return
  end

  /* ---- FILTERS (2..n-1) ---- */
  i = 2
  do while i < stages[0]
    s = stages[i]
    t = getStageType(s)

    if t = 'LOCATE' then      lines = stage_LOCATE(lines, s)
    else if t = 'CHANGE' then lines = stage_CHANGE(lines, s)
    else if t = 'SPECS' then  lines = stage_SPECS(lines, s)
    else if t = 'DROP' then   lines = stage_DROP(lines, s)
    else if t = 'TAKE' then   lines = stage_TAKE(lines, s)
    else if t = 'COUNT' then  lines = stage_COUNT(lines, s)
    else if t = 'TRACE' then  lines = stage_TRACE(lines, s)
    else if t = 'SORT' then   lines = stage_CMD(lines, 'CMD sort' || substr(s, 5))    /* shorthand for OS sort; reuse CMD handler */
    else if t = 'CMD' then    lines = stage_CMD(lines, s)
    else if t = 'FIELD' then  lines = stage_FIELD(lines, s)
    else if t = 'UNIQUE' then lines = stage_UNIQUE(lines, s)
    else if t = 'PAD' then    lines = stage_pad(lines, s)
    else if t = 'UPPER'  then lines = stage_UPPER(lines, s)
    else if t = 'LOWER'  then lines = stage_LOWER(lines, s)
    else if t = 'TRIM'   then lines = stage_TRIM(lines, s)
    else if t = 'CONSOLE' then call writeSink_CONSOLE lines  /* tee to console, pass through */
    /* else: unknown → no-op (or warn) */
    i = i + 1
  end

  /* ---- SINK (last) ---- */
  last = stages[stages[0]]
  lt   = getStageType(last)

  if lt = 'WRITE' then        call writeSink_FILE last, lines
  else if lt = 'CONSOLE' then call writeSink_CONSOLE lines
  else if lt = 'NULL' then    nop
  else if lt = 'CMD' then     call writeSink_CMD last, lines
  else call writeSink_CONSOLE lines  /* default: console */
  return


readSource_FILE: procedure=.string[]
  arg stage=.string
  parse var stage . rest
  rest = strip(substr(stage, 2))
  fn = unquote(rest)
  lines = .string[]
  /* ExecIO (DISKR) fills lines[...] automatically */
  lines=ReadAll(fn)
return lines

readSource_CMD: procedure=.string[]
  arg stage=.string
  cmd = strip(substr(stage,4))
  out = .string[]
  h = processcreate(cmd, 1)
  if h < 0 then do; say 'Cannot start source:' cmd; return out; end
  call processsettimeout h, 600000

  do forever
    l = processreadoutput(h)
    if l='' then do
      call processwait h, 50
      if processgetexitcode(h)\=-1 then leave
      iterate
    end
    out[out[0]+1] = l
  end
  call processfree h
return out

stage_LOCATE: procedure=.string[]
  arg lines=.string[], stage=.string
  parse var stage . rest
  pat = unquote(strip(rest))
  kept = .string[]
  do k=1 to lines[0]
     if pos(pat, lines[k])>0 then kept[kept[0]+1]=lines[k]
  end
return kept

stage_CHANGE: procedure=.string[]
  arg lines=.string[], stage=.string
  old=word(stage,2)
  new=word(stage,3)
  old = unquote(old);
  new = unquote(new)
  do k=1 to lines[0]
    lines[k] = changestr(old,lines[k],new)
  end
return lines


stage_SPECS: procedure=.string[]
  arg lines=.string[], stage=.string
  parse upper var stage . rest
  parse var rest s1 '-' s2 .
  if \datatype(s1,'W') then s1=1
  if \datatype(s2,'W') then s2=s1
  if s1<1 then s1=1
  if s2<s1 then s2=s1
  do k=1 to lines[0]
    lines[k] = substr(lines[k], s1, s2 - s1 + 1)
  end
return lines

stage_DROP: procedure=.string[]
  arg lines=.string[], stage=.string
  parse upper var stage . count .
  n=count+0
  if \datatype(n,'W') then n=0
  kept = .string[]
  do k=n+1 to lines[0]
    kept[kept[0]+1] = lines[k]
  end
return kept

stage_TAKE: procedure=.string[]
  arg lines=.string[], stage=.string
  parse upper var stage . n .
  if \datatype(n,'W') then n=lines[0]
  kept = .string[]
  lim = n; if lim>lines[0] then lim=lines[0]
  do k=1 to lim
    kept[kept[0]+1] = lines[k]
  end
return kept

stage_CMD: procedure=.string[]
  arg lines=.string[], stage=.string
  /* stage is like: 'CMD sort /r TIMEOUT=5000 SYNC' or plain 'CMD "awk ..."' */
  raw = strip(substr(stage,4))
  cmds=parseCmdFlags(raw)
  cmd=cmds[1]
  sync=cmds[2]
  tout=cmds[3]

  h = processcreate(cmd, 1)
  if h < 0 then do; say 'Cannot start filter:' cmd; return lines; end
  if tout>0 then call processsettimeout h, tout
  else call processsettimeout h, 600000
  do k=1 to lines[0]
    call processsendinput h, lines[k] || "0a"x
  end
  call processcloseinput h
  if sync\='' then call processwait h, 0
  out=.string[]
  do forever
    r = processreadoutput(h)
    if r='' then do
      if sync then leave
      call processwait h, 50
      if processgetexitcode(h)\=-1 then leave
      iterate
    end
    out[out[0]+1] = r
  end
  call processfree h
return out

writeSink_FILE: procedure
  arg stage=.string, lines=.string[]
  fn = unquote(strip(substr(stage,2)))
  ExecIO * DISKW fn stem lines
return

writeSink_CONSOLE: procedure
  arg lines=.string[]
  say "-- Console of array --"
  do k=1 to lines[0]; say right(k,4,'0') lines[k]; end
  say "-- End of Console --"
return

writeSink_CMD: procedure
  arg stage=.string, lines=.string[]
  raw = strip(substr(stage,4))
  cmds= parseCmdFlags(raw)
  ## parse value strg with cmd sync tout
  cmd=cmds[1]
  sync=cmds[2]
  tout=cmds[3]
  hs = processcreate(cmd, 1)
  if hs < 0 then do; say 'Cannot start sink:' cmd; return; end
  if tout>0 then call processsettimeout hs, tout
  else call processsettimeout hs, 600000

  do k=1 to lines[0]
    call processsendinput hs, lines[k] || "0a"x
  end
  call processcloseinput hs
  if sync then call processwait hs, 0

  do forever
    rr = processreadoutput(hs)
    if rr='' then do
      if sync then leave
      call processwait hs, 50
      if processgetexitcode(hs)\=-1 then leave
      iterate
    end
    say rr
  end
  call processfree hs
return

/* FIELD n [SEP "char"]  → keep the nth field (1-based)
   Examples:
     FIELD 2
     FIELD 1 SEP ","
*/
stage_FIELD: procedure=.string[]
  arg lines=.string[], stage=.string

  parse upper var stage . rest
  parse var rest n .         /* default whitespace split */
  if \datatype(n,'W') then n = 1

  /* optional: SEP "x" */
  sep = ''
  if wordpos('SEP', rest) > 0 then do
    /* grab the token after SEP (quoted or not) */
    parse var rest . 'SEP' sepspec .
    /* allow SEP "," or SEP ","rest... ; unquote handles both */
    sep = unquote(sepspec)
  end
  out = .string[]
  if sep = '' then do
    /* whitespace-delimited */
    do k = 1 to lines[0]
      out[out[0]+1] = word(lines[k], n)
    end
  end
  else do
    /* custom single-char separator */
    do k = 1 to lines[0]
      out[out[0]+1] = getFieldBySep(lines[k], n, sep)
    end
  end
return out

getFieldBySep: procedure=.string
  arg s=.string, n=.string, sep=.string
  if sep = '' then return s
  /* simple split by single character sep */
  cnt = 0
  p = 1
  do forever
    q = pos(sep, s, p)
    if q = 0 then do
      cnt = cnt + 1
      if cnt = n then return substr(s, p)
      return ''         /* n past last field */
    end
    cnt = cnt + 1
    if cnt = n then return substr(s, p, q - p)
    p = q + length(sep)
  end
return '???'


/* UNIQUE — remove duplicate lines (stable) */
stage_UNIQUE: procedure=.string[]
  arg lines=.string[], stage=.string
  seen = .string[]
  do k = 1 to lines[0]
     l = lines[k]
     if l='' then iterate
     new=1
     do j=1 to seen[0]
        if seen[j]\=l then iterate
        new=0
        leave
     end
     if new = 1 then seen[seen[0]+1]=l
  end
return seen

/* UPPER / LOWER */
stage_UPPER: procedure=.string[]
  arg lines=.string[], stage=.string
  do k=1 to lines[0]; lines[k] = upper(lines[k]); end
return lines

stage_LOWER: procedure=.string[]
  arg lines=.string[], stage=.string
  do k=1 to lines[0]
    lines[k] = lower(lines[k])
  end
return lines

/* TRIM [L|R] (default both sides) */
stage_TRIM: procedure=.string[]
  arg lines=.string[], stage=.string
  parse upper var stage . side .
  do k=1 to lines[0]
    if side = 'L' then lines[k] = strip(lines[k], 'L')
    else if side = 'R' then lines[k] = strip(lines[k], 'T')
    else lines[k] = strip(lines[k])
  end
return lines

/* PAD width [LEFT|RIGHT] (default RIGHT) */
stage_PAD: procedure=.string[]
  arg lines=.string[], stage=.string
  parse upper var stage . wstr align .
  w=wstr+0
  if \datatype(w,'W') then w = 0
  if align = '' then align = 'RIGHT'
  do k=1 to lines[0]
    len = length(lines[k])
    if len >= w then iterate
    fill = copies(' ', w - len)
    if align = 'LEFT' then lines[k] = lines[k] || fill
    else lines[k] = fill || lines[k]
  end
return lines

/* COUNT — replace stream with single number */
stage_COUNT: procedure=.string[]
  arg lines=.string[], stage=.string
  out = .string[]
  out[1] = lines[0]
return out

/* TRACE [label] — echo to console, passthrough unchanged */
stage_TRACE: procedure=.string[]
  arg lines=.string[], stage=.string
  parse var stage . label
  if label = '' then label = 'TRACE'
  do k=1 to lines[0]; say '['label']' lines[k]; end
return lines


parseCmdFlags: procedure=.string[]
  /* Input: full 'CMD ...' tail without 'CMD'
     Output (via PARSE VALUE): cmd sync tout */
  arg s=.string
  su = translate(s)
  /* TIMEOUT=ms */
  tout = 0
  posT = pos(' TIMEOUT=', su)
  if posT>0 then do
    eq = posT + 9
    left = strip(substr(s,1,posT-1))
    right = substr(s,eq)
    parse var right n rest
    if datatype(n,'W') then tout=n
    s = strip(left || rest)
  end
  /* SYNC token */
  sync = 0
  out=''
  do i=1 to words(s)
    w=word(s,i)
    if translate(w)='SYNC' then sync=1
    else out = out w
  end
  cmd = strip(out)
  cmds=.string[]
  cmds[1]=cmd
  cmds[2]=sync
  cmds[3]=tout
return cmds


swapArrays: procedure
  arg expose A=.string[], expose B=.string[]
  ai = a[0] ; bi = b[0]
  /* copy B -> A */
  clear A               ## reset stem A
  do i = 1 to bi;
     A[i] = B[i]
  end
  clear B               ## reset stem B
return

parseTimeout: procedure=.string
  /* returns integer ms from '... TIMEOUT=1234' or 0 if absent */
  arg sU=.string
  posT = pos(' TIMEOUT=', sU)
  if posT = 0 then return 0
  val = strip(substr(sU, posT + 9))
  parse var val n .          /* first token after '=' */
  if datatype(n, 'W') then return n
return 0

hasSyncFlag: procedure=.string
  arg sU=.string
return wordpos('SYNC', sU) > 0

stripFlags: procedure=.string
  /* remove SYNC and TIMEOUT=... from a CMD stage line, return clean command */
  arg s=.string
  sU = translate(s)
  posT = pos(' TIMEOUT=', sU); if posT > 0 then do
    eq = posT + 9
    rest = substr(s, 1, posT-1)
    rem  = substr(s, eq)
    parse var rem num rest2
    s = strip(rest || rest2)
  end
  /* remove bare token SYNC (case-insensitive) */
  out = ''
  do i = 1 to words(s)
    w = word(s, i)
    if translate(w) = 'SYNC' then iterate
    out = out w
  end
return strip(out)

min: procedure=.string
  arg a=.string,b=.string
  if a<b then return a
return b
