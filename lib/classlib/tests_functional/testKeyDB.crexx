/* rexx */
options levelb comments_dash
import data_KeyDB
import rxfnsb

kdb = .KeyDB()
failures = 0

handle = kdb.open("testKeyDB.db", "w+")
if handle < 0 then do
  say "Failed to open key database:" handle
  return 1
end

rc = kdb.begin()
failures = failures + check_int("begin", rc, 0)
failures = failures + check_int("put alpha", kdb.put("alpha", "one"), 0)
failures = failures + check_int("put beta", kdb.put("beta", "two"), 0)
rc = kdb.commit()
failures = failures + check_int("commit", rc, 0)

failures = failures + check_string("get alpha", kdb.get("alpha"), "one")
failures = failures + check_string("get beta", kdb.get("beta"), "two")
failures = failures + check_int("contains alpha", kdb.containsKey("alpha"), 1)
failures = failures + check_int("size after insert", kdb.size(), 2)
failures = failures + check_int("validate", kdb.validate(), 0)

failures = failures + check_int("remove beta", kdb.removeCommit("beta"), 0)

stats = kdb.stats()
if length(stats) = 0 then do
  say "stats returned an empty string"
  failures = failures + 1
end

rc = kdb.close()
failures = failures + check_int("close", rc, 0)

handle = kdb.open("testKeyDB.db", "r")
if handle < 0 then do
  say "Failed to reopen key database:" handle
  failures = failures + 1
end
else do
  failures = failures + check_string("get alpha after reopen", kdb.get("alpha"), "one")
  failures = failures + check_int("contains beta after reopen", kdb.containsKey("beta"), 0)
  failures = failures + check_string("get beta after reopen", kdb.get("beta"), "NOT_FOUND")
  failures = failures + check_int("close after reopen", kdb.close(), 0)
end

if failures > 0 then do
  say "testKeyDB failed:" failures "check(s)"
  return 1
end

say "testKeyDB ok"
return 0

check_int: procedure = .int
  arg label = .string, actual = .int, expected = .int
  if actual = expected then return 0
  say label "expected" expected "got" actual
  return 1

check_string: procedure = .int
  arg label = .string, actual = .string, expected = .string
  if actual = expected then return 0
  say label "expected" expected "got" actual
  return 1
