options levelb comments_dash
import data_StringList

failures = 0

l = .StringArrayList()

failures = failures + check_int("new list size", l.size(), 0)
failures = failures + check_int("new list empty", l.isEmpty(), 1)

rc = l.add("B")
rc = l.append("C")
rc = l.prepend("A")
failures = failures + check_int("append/prepend size", l.size(), 3)
failures = failures + check_string("append/prepend first", l.get(1), "A")
failures = failures + check_string("append/prepend second", l.get(2), "B")
failures = failures + check_string("append/prepend third", l.get(3), "C")

rc = l.insert(2, "X")
failures = failures + check_int("insert size", l.size(), 4)
failures = failures + check_string("insert value", l.get(2), "X")
failures = failures + check_string("insert shifted", l.get(3), "B")

failures = failures + check_string("remove value", l.remove(2), "X")
failures = failures + check_int("remove size", l.size(), 3)
failures = failures + check_string("remove shifted", l.get(2), "B")

failures = failures + check_int("contains present", l.contains("C"), 1)
failures = failures + check_int("contains absent", l.contains("X"), 0)
failures = failures + check_int("indexOf present", l.indexOf("C"), 3)
failures = failures + check_int("indexOf from miss", l.indexOf("A", 2), 0)

rc = l.set(2, "D")
failures = failures + check_string("set value", l.get(2), "D")

live = l.iterator()
snapshot_it = l.snapshotIterator()

rc = l.set(2, "Y")
rc = l.add("E")

failures = failures + check_int("snapshot iterator live", snapshot_it.isLive(), 1)
failures = failures + check_string("snapshot iterator first", snapshot_it.next(), "A")
failures = failures + check_string("snapshot iterator stable changed", snapshot_it.next(), "D")
failures = failures + check_string("snapshot iterator stable appended", snapshot_it.next(), "C")
failures = failures + check_int("snapshot iterator ignores append", snapshot_it.hasNext(), 0)

failures = failures + check_int("live iterator live", live.isLive(), 1)
failures = failures + check_string("live iterator first", live.next(), "A")
failures = failures + check_string("live iterator observes change", live.next(), "Y")
failures = failures + check_string("live iterator third", live.next(), "C")
failures = failures + check_int("live iterator sees append", live.hasNext(), 1)
failures = failures + check_string("live iterator appended", live.next(), "E")
failures = failures + check_int("live iterator end", live.hasNext(), 0)

call l.clear()
failures = failures + check_int("clear size", l.size(), 0)
failures = failures + check_int("clear empty", l.isEmpty(), 1)

if failures <> 0 then do
  say "StringArrayList failures:" failures
  exit 1
end

say "PASS: StringArrayList"
exit 0

check_int: procedure=.int
  arg label=.string, actual=.int, expected=.int

  if actual <> expected then do
    say label": expected" expected "got" actual
    return 1
  end
return 0

check_string: procedure=.int
  arg label=.string, actual=.string, expected=.string

  if actual <> expected then do
    say label": expected ["expected"] got ["actual"]"
    return 1
  end
return 0
