options levelb comments_dash
import data
-- import data_StringLinkedList
import rxfnsb

failures = 0

l = .StringLinkedList()

rc = l.append("aap")
rc = l.append("noot")
rc = l.prepend("mies")

-- say l.toString()         -- {mies, aap, noot}

rc = l.setFirst()
say l.current()          -- mies
say l.next()             -- aap
say l.next()             -- noot
say l.next()             -- ""

rc = l.insertBeforeCurrent("jet")
-- say l.toString()

rc = l.clear()
failures = failures + check_int("cleared list size", l.size(), 0)
failures = failures + check_int("cleared list empty", l.isEmpty(), 1)
failures = failures + check_int("cleared setFirst", l.setFirst(), 4)
failures = failures + check_int("append after clear", l.append("after"), 1)
failures = failures + check_int("size after clear append", l.size(), 1)
rc = l.setFirst()
failures = failures + check_int("setFirst after clear append", rc, 0)
failures = failures + check_string("current after clear append", l.current(), "after")

k = .StringLinkedList()
rc = k.append("wim")
rc = k.append("zus")
rc = k.prepend("jet")

rc = k.setFirst()
say k.current()          -- mies
say k.next()             -- aap
say k.next()             -- noot
say k.next()             -- ""

call k.debug()

x = .string[]
x = k.toArray()
say 'size of k:' x[0]

say x[1]
say x[2]
say x.3

say k.size()

say k.toString()

blank_list = .StringLinkedList()
rc = blank_list.clear()
rc = blank_list.append(" ")
failures = failures + check_int("blank list is not empty", blank_list.isEmpty(), 0)
rc = blank_list.setFirst()
blank_current = blank_list.current()
failures = failures + check_int("blank current length", length(blank_current), 1)
blank_items = .string[]
blank_items = blank_list.toArray()
failures = failures + check_int("blank toArray count", blank_items.0, 1)
blank_item = blank_items.1
failures = failures + check_int("blank toArray item length", length(blank_item), 1)

if failures <> 0 then do
  say "StringLinkedList failures:" failures
  exit 1
end

say "PASS: StringLinkedList"
exit 0

check_int: procedure=.int
  arg label=.string, actual=.int, expected=.int

  if actual <> expected then do
    say label": expected" expected "got" actual
    return 1
  end
return 0

check_string: procedure=.int
  arg label=.string, actual=.string, expected=.string

  if actual <> expected then do
    say label": expected ["expected"] got ["actual"]"
    return 1
  end
return 0
