options levelb comments_dash
import system_Os
import rxfnsb

x = .Os()
failures = 0

failures = failures + check_non_empty("uptime", x.uptime())
failures = failures + check_non_empty("user", x.user())
failures = failures + check_non_empty("loadpath", x.loadpath())
failures = failures + check_non_empty("osname", x.osname())
failures = failures + check_non_empty("getHost", x.getHost())
home = x.getEnv("HOME")
if length(home) = 0 then home = x.getEnv("USERPROFILE")
failures = failures + check_non_empty("getEnv HOME/USERPROFILE", home)

wait_rc = x.wait(1)
if wait_rc < 0 then do
  say "wait returned" wait_rc
  failures = failures + 1
end

if failures > 0 then do
  say "testOS failed:" failures "check(s)"
  return 1
end

say "testOS ok"
return 0

check_non_empty: procedure = .int
  arg label = .string, value = .string
  if length(value) > 0 then return 0
  say label "returned an empty string"
  return 1
