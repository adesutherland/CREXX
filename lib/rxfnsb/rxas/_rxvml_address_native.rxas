/*
 * Compile-time declaration for the rxvml-hosted native ADDRESS trampoline.
 *
 * The implementation is provided by interpreter/rxvml.c when a host creates an
 * rxvml_context. This declaration lets the Rexx ADDRESS library type-check the
 * nativeaddressenvironment proxy without packaging a Rexx fallback body.
 */
_native_address_execute() .locals=0 .expose=_rxsysb._native_address_execute
  .meta "_rxsysb._native_address_execute"="b" ".int" _native_address_execute() "handle = .int, request = .addressrequest" ""
