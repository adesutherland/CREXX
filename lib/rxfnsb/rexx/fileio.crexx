/*
 * CREXX LEVEL B - FILE IO Functions
 */
options levelb
namespace rxfnsb expose lineout linein lines charin charout _execio readlines loadtext
import _rxsysb

/* Level B UTF text lineout BIF. Writes one line and appends a newline. */
lineout: procedure = .int
    arg fname = "stdout", line = ""
    if fname = "" then fname = "stdout" /* In case of blank argument */

    if ?line then do
        /* line specified - open file */
        nl = '0a'x
        fileid = _open(fname, "w")
        if fileid = 0 then say "ERROR lineout() file" fname "could not open"
        assembler fwrite fileid,line
        assembler fwrite fileid,nl
    end
    
    else do
        /* line not specified - close file */
        call clear_line_pending fname
        call _close fname
    end
    return 0

/* Level B UTF text linein BIF. Reads one line without the line terminator. */
linein: procedure = .string expose _linein_pending_names _linein_pending_values _linein_pending_present
    arg fname = "stdin"
    if fname = "" then fname = "stdin" /* In case of blank argument */

    line = ""
    pending_index = find_line_pending(fname)
    if pending_index > 0 then do
        line = _linein_pending_values[pending_index]
        _linein_pending_values[pending_index] = ""
        _linein_pending_present[pending_index] = 0
        return line
    end

    fileid = _open(fname, "r")
    if fileid = 0 then call write_stderr "ERROR linein() file" fname "could not open"
    assembler freadline line,fileid
    return line

/* REXX Lines BIF. Returns -1 when the stream cannot be opened. */
lines: procedure = .int expose _linein_pending_names _linein_pending_values _linein_pending_present
    arg fname = "stdin"
    if fname = "" then fname = "stdin" /* In case of blank argument */

    line = ""
    pending_index = find_line_pending(fname)
    if pending_index > 0 then return 1

    fileid = _open(fname, "r")
    if fileid = 0 then do
        call write_stderr "ERROR lines() file" fname "could not open"
        return -1
    end

    eof = 0
    assembler feof eof,fileid

    if eof > 0 then return 0

    assembler freadline line,fileid
    assembler feof eof,fileid
    if eof > 0 & line = "" then return 0

    call set_line_pending fname, line
    return 1

/* Level B UTF text charin BIF. Reads codepoints, not arbitrary bytes. */
charin: procedure = .string
    arg fname = "stdin", count = 1
    if fname = "" then fname = "stdin" /* In case of blank argument */
    if count <= 0 then return ""

    result = ""
    fileid = _open(fname, "r")
    if fileid = 0 then do
        say "ERROR charin() file" fname "could not open"
        return ""
    end

    eof = 0
    do i = 1 to count while eof = 0
        char = ""
        assembler freadcdpt char,fileid
        assembler feof eof,fileid
        if eof > 0 & char = "" then leave
        result = result || char
    end
    return result

/* Level B UTF text charout BIF. Writes text without appending a newline. */
charout: procedure = .int
    arg fname = "stdout", text = ""
    if fname = "" then fname = "stdout" /* In case of blank argument */

    if ?text then do
        /* text specified - open file */
        fileid = _open(fname, "w")
        if fileid = 0 then do
            say "ERROR charout() file" fname "could not open"
            return 1
        end
        assembler fwrite fileid,text
    end
    
    else do
        /* line not specified - close file */
        call _close fname
    end
    return 0

/* REXX EXECIO BIF */
_execio: procedure=.int
  arg mmax=.string,mode='R',fname=.string, expose stem=.string[]
  maxrec=0
  mode=upper(strip(mode))
  /* say 'EXECIO Debug mode='mode', file='fname', records='mmax */
  count=0
  if mode='DISKR'       then omode='r'
  else if mode='READ'   then omode='r'
  else if mode='DISKW'  then omode='w'
  else if mode='WRITE'  then omode='w'
  else if mode='DISKA'  then omode='a'
  else if mode='APPEND' then omode='a'
  fileid=0

  assembler fopen fileid,fname,omode

  if fileid=0 then return -12
  if omode='r' then do
     if mmax='*' then maxrec=9999999
     else maxrec=mmax
     line=''
     eof=0
     assembler SETATTRS stem,0
     do while eof=0 & count<maxrec
        assembler freadline line,fileid
        assembler feof eof,fileid
        if eof > 0 & line = '' then leave
        count=count+1
        stem.count=line
     end
  end
  else do
    nl = '0a'x
    if mmax='*' then maxrec=stem.0
    else maxrec=min(mmax,stem.0)
    do count=1 to maxrec
       assembler fwrite fileid,stem.count
       if count<maxrec then assembler fwrite fileid,nl  /* do not write nl for last record, as a last empty record appears */
    end
  end
  rc=0
  assembler fclose rc,fileid
  if rc\=0 then return rc
return count

/* -------------------------------------------------------------------------------
 * readLines — Read text file records into a string array.
 *
 * Syntax:
 *     lines = readLines(fileName
 *                       [, fromLine = 1
 *                       [, maxRecords = 0]])
 *
 * Parameters:
 *     fileName    : .string
 *         Path to the input text file.
 *
 *     fromLine    : .int (optional, default = 1)
 *         1-based index of the first line to return.
 *         Must be >= 1.
 *
 *     maxRecords  : .int (optional, default = 0)
 *         Maximum number of records to return.
 *         If <= 0, all remaining lines from fromLine are returned.
 *
 * Returns:
 *     .string[] array
 *         A dense array containing the selected lines.
 *         Indexing starts at 1.
 *
 * Semantics:
 *     - Lines are returned without trailing CR/LF characters.
 *     - Supports ASCII and UTF-8 encoded text files.
 *     - Physical empty lines inside the file are preserved.
 *     - A trailing newline at physical EOF does NOT create
 *       an additional empty array entry.
 *
 * Error Handling:
 *     - Raises condition "error", code "40.27" if:
 *           * file cannot be opened
 *           * file cannot be closed
 *           * invalid parameter values are supplied
 *     - Read errors propagate as runtime exceptions from freadline.
 *
 * Notes:
 *     - This function loads the selected range fully into memory.
 *       Not suitable for extremely large files.
 *     - File handle is always closed before return.
 *
 * -------------------------------------------------------------------------------
 */
readlines: procedure = .string[]
  arg fname=.string, from=1, maxrec=0, xError='raise'   /* maxrec=0 => all remaining */

  if from < 1   then from=1
  if maxrec < 0 then maxrec=0

  eof=0
  in_no=0
  out_no=0
  fileid=0
  llen=0
  rmode="r"
  lines=.string[]
  assembler fopen fileid,fname,rmode
  if fileid=0 then do
     if upper(xError)='RAISE' then call raise "error", "40.27", "cannot open "fname
     lines[1]='-8 OPEN ERROR'    /* return array with error message */
     return lines
  end

  do while eof = 0
     line = ""
     assembler freadline line, fileid
     assembler feof eof, fileid
     if eof > 0 & line = "" then leave    /* stop on the final read-at-EOF empty result */

     in_no = in_no + 1
     if in_no < from then iterate

     out_no = out_no + 1
     if maxrec > 0 & out_no > maxrec then leave

     lines[out_no] = line
  end

  rc=0
  assembler fclose rc,fileid
  if rc\=0 then call raise "error", "40.27", "cannot close "fname
return lines
/* Load entire non Binary file into one stream and returns it
 */
loadtext: procedure = .string
  arg fname=.string

  stream=.string
  eof=.int
  fileid=0
  rc=0
  rmode="r"

  assembler fopen fileid,fname,rmode
  if fileid=0 then call raise "error", "40.27", "cannot open "fname
  do while eof = 0
     line = ""
     assembler freadline line, fileid
     assembler feof eof, fileid
     if eof > 0 & line = "" then leave    /* stop on the final read-at-EOF empty result */
     stream = stream||line||'0D0A'x
  end
  assembler fclose rc,fileid
  if rc\=0 then call raise "error", "40.27", "cannot close "fname
return stream

write_stderr: procedure = .void
  arg message = .string
  fileid = 0
  target = "stderr"
  mode = "w"
  nl = '0a'x
  assembler fopen fileid,target,mode
  if fileid = 0 then return
  assembler fwrite fileid,message
  assembler fwrite fileid,nl
  return

find_line_pending: procedure = .int expose _linein_pending_names _linein_pending_values _linein_pending_present
  arg fname = .string
  _linein_pending_names = .string[]
  _linein_pending_values = .string[]
  _linein_pending_present = .int[]
  do i = 1 to _linein_pending_names.0
    if _linein_pending_present[i] = 1 & _linein_pending_names[i] = fname then return i
  end
  return 0

set_line_pending: procedure = .void expose _linein_pending_names _linein_pending_values _linein_pending_present
  arg fname = .string, line = .string
  _linein_pending_names = .string[]
  _linein_pending_values = .string[]
  _linein_pending_present = .int[]
  empty_slot = 0
  do i = 1 to _linein_pending_names.0
    if _linein_pending_names[i] = fname then do
      _linein_pending_values[i] = line
      _linein_pending_present[i] = 1
      return
    end
    if empty_slot = 0 & _linein_pending_present[i] = 0 then empty_slot = i
  end
  if empty_slot = 0 then empty_slot = _linein_pending_names.0 + 1
  _linein_pending_names[empty_slot] = fname
  _linein_pending_values[empty_slot] = line
  _linein_pending_present[empty_slot] = 1
  return

clear_line_pending: procedure = .void expose _linein_pending_names _linein_pending_values _linein_pending_present
  arg fname = .string
  _linein_pending_names = .string[]
  _linein_pending_values = .string[]
  _linein_pending_present = .int[]
  do i = 1 to _linein_pending_names.0
    if _linein_pending_names[i] = fname then do
      _linein_pending_values[i] = ""
      _linein_pending_present[i] = 0
      return
    end
  end
  return
