/* rexx */
options levelb

import rexxscript

errors = 0

result = rexxscript_evaluate("a = 1; say 'starting'; say a; a = a + 2", 0)
out = rexxscript_output()

if result[1] <> "OK" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE status failed:" result[1]
end

if result[2] <> "a" | result[3] <> "3" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE export failed:" result[2] result[3]
end

if out[0] <> 2 | out[1] <> "starting" | out[2] <> "1" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE output failed:" out[0] out[1] out[2]
end

names = .string[]
values = .string[]
names[1] = "a"
values[1] = "7"
names[2] = "message"
values[2] = ""

result = rexxscript_evaluate_exposed("say a; a = a + 3; message = 'total ' || a", names, values, 0)
out = rexxscript_output()

if result[1] <> "OK" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE_EXPOSED status failed:" result[1]
end

if rexxscript_value("a") <> "10" | rexxscript_value("message") <> "total 10" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE_EXPOSED value failed:" rexxscript_value("a") rexxscript_value("message")
end

if out[0] <> 1 | out[1] <> "7" then do
  errors = errors + 1
  say "REXXSCRIPT_EVALUATE_EXPOSED output failed:" out[0] out[1]
end

runner = .rexxscriptevaluator()
result = runner.evaluate("if 0 then do; say 'bad'; end; say 'good'", 0)
out = rexxscript_output()

if result[1] <> "OK" then do
  errors = errors + 1
  say "REXXSCRIPT evaluator status failed:" result[1]
end

if out[0] <> 1 | out[1] <> "good" then do
  errors = errors + 1
  say "REXXSCRIPT evaluator skipped block failed:" out[0] out[1]
end

if errors = 0 then say "PASS: RexxScript runtime"
else say "FAIL: RexxScript runtime" errors

return errors <> 0
