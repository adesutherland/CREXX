   .srcstep 1 1 17 "utf1.crexx" 4 1 72 "多变的 = \"多变的 is 'variable' in Chinese (according to Google!)\""
   .meta "utf1.main.多变的"="b" ".string" r4
   load r4,"\xe5\xa4\x9a\xe5\x8f\x98\xe7\x9a\x84 is \'variable\' in Chinese (according to Google!)"
   .traceevent "L" 4 "R" "S" "r" 4 1 1 0 "" ""
   .traceevent "A" 6 "R" "S" "r" 4 1 1 0 "多变的" ""
   .srcstep 2 2 17 "utf1.crexx" 5 1 14 "SAY 多变的"
   .traceevent "V" 6 "R" "S" "r" 4 2 2 0 "多变的" ""
   say r4
   .srcstep 3 3 17 "utf1.crexx" 7 1 33 "équipe = \"René Vincent Jansen\""
   .meta "utf1.main.équipe"="b" ".string" r3
   load r3,"Ren\xc3\xa9 Vincent Jansen"
   .traceevent "L" 4 "R" "S" "r" 3 3 3 0 "" ""
   .traceevent "A" 6 "R" "S" "r" 3 3 3 0 "équipe" ""
   .srcstep 4 4 17 "utf1.crexx" 8 1 37 "équipe = équipe \", Mike Großmann\""
   .traceevent "V" 6 "R" "S" "r" 3 4 4 0 "équipe" ""
   sconcat r3,r3,", Mike Gro\xc3\x9fmann"
   .traceevent "O" 4 "R" "S" "r" 3 4 4 0 "" ""
   .traceevent "A" 6 "R" "S" "r" 3 4 4 0 "équipe" ""
   .srcstep 5 5 17 "utf1.crexx" 9 1 72 "équipe = équipe \" and all the rest (this is just a UTF-8 test! 😊)\""
   .traceevent "V" 6 "R" "S" "r" 3 5 5 0 "équipe" ""
   sconcat r3,r3," and all the rest (this is just a UTF-8 test! \xf0\x9f\x98\x8a)"
   .traceevent "O" 4 "R" "S" "r" 3 5 5 0 "" ""
   .traceevent "A" 6 "R" "S" "r" 3 5 5 0 "équipe" ""
   .srcstep 6 6 17 "utf1.crexx" 11 1 29 "Say \"cREXX Équipe:\" ÉQUIPE"
   .traceevent "V" 6 "R" "S" "r" 3 6 6 0 "équipe" ""
   sconcat r5,"cREXX \xc3\x89quipe:",r3
   .traceevent "O" 4 "R" "S" "r" 5 6 6 0 "" ""
   say r5
   .srcstep 7 7 17 "utf1.crexx" 14 1 14 "Großmann = 1"
