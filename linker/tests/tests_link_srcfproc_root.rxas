/*
 * linker/tests/tests_link_srcfproc_root.rxas
 */

.globals=0

main() .locals=6
   load r1,1
   load r2,"mini"
   settp r2,768
   srcfprocsel r0,"rxsig1|link_iface.shape..from_name|.shape|name=.string",r1
   dcall r0,r0,r1

   load r1,1
   settp r0,256
   swap r2,r0
   srcmethodsel r3,r2,"rxsig1|describe|.string|"
   dcall r3,r3,r1
   swap r0,r2
   seq r4,r3,"linked-named-box"
   brf fail,r4
   say "PASS: SRCFPROC Linked"
   ret 0

fail:
   say "FAIL: SRCFPROC Linked"
   say r3
   ret 0
