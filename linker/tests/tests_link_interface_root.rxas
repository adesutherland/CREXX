/*
 * linker/tests/tests_link_interface_root.rxas
 */

.meta "link_iface.shape"="b" ".unknown" .interface
.meta "link_iface.shape"="method" "describe" ".string" "" .member
.meta "link_iface.shape"="factory" "*" ".shape" "" .member

.globals=0

main() .locals=6
   load r1,0
   srcfprocsel r0,"rxsig1|link_iface.shape|.shape|",r1
   dcall r0,r0,r1

   load r1,1
   settp r0,256
   swap r2,r0
   srcmethodsel r3,r2,"rxsig1|describe|.string|"
   dcall r3,r3,r1
   swap r0,r2
   seq r4,r3,"linked-box"
   brf fail,r4
   say "PASS: Interface Linked"
   ret 0

fail:
   say "FAIL: Interface Linked"
   say r3
   ret 0
