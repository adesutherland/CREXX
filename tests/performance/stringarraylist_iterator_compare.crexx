/* Observational classlib comparison for StringArrayList iterator shapes. */
options levelb
import rxfnsb
import data_StringList

rounds = 4000
expected = rounds * 6

list = .StringArrayList()
call list.add("A")
call list.add("BB")
call list.add("CCC")

start = time("us")
live = list.iterator()
live_factory_elapsed = time("us") - start

start = time("us")
snapshot_it = list.snapshotIterator()
snapshot_factory_elapsed = time("us") - start

start = time("us")
direct_checksum = runDirect(list, rounds)
direct_elapsed = time("us") - start

start = time("us")
live_checksum = runIterator(live, rounds)
live_elapsed = time("us") - start

start = time("us")
snapshot_checksum = runIterator(snapshot_it, rounds)
snapshot_elapsed = time("us") - start

if direct_checksum <> expected then return fail("direct checksum")
if live_checksum <> expected then return fail("live checksum")
if snapshot_checksum <> expected then return fail("snapshot checksum")

say "benchmark=stringarraylist_iterator_compare"
say "rounds="rounds
say "live_factory_us="live_factory_elapsed
say "snapshot_factory_us="snapshot_factory_elapsed
say "direct_elapsed_us="direct_elapsed
say "live_elapsed_us="live_elapsed
say "snapshot_elapsed_us="snapshot_elapsed
say "checksum="snapshot_checksum
say "PASS: StringArrayList StringIterator Performance Smoke"
return 0

runDirect: procedure = .int
  arg list = .StringArrayList, rounds = .int
  checksum = 0
  do pass = 1 to rounds
    checksum = checksum + length(list.get(1))
    checksum = checksum + length(list.get(2))
    checksum = checksum + length(list.get(3))
  end
  return checksum

runIterator: procedure = .int
  arg iterator = .StringArrayListIterator, rounds = .int
  checksum = 0
  do pass = 1 to rounds
    call iterator.reset()
    do while iterator.hasNext()
      checksum = checksum + length(iterator.next())
    end
  end
  return checksum

fail: procedure = .int
  arg label = .string
  say "FAIL:" label
  return 1
