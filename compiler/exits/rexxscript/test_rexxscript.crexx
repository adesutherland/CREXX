options levelb
import rexxscript

main: procedure
  failures = .int
  out = .string[]
  raw = .string[]
  a = .string
  message = .string
  failures = 0

  a = 1
  b = "11"
  message = ""
  say "Sample 1"
  say "--------"
  REXXSCRIPT "say 'script starting'; say a; a = a + 4;b='Alpha'; message = 'done ' || a" EXPOSE a,b, message OUTPUT out RESULT raw DEBUG
  say "Status of executed script "script_status
  if raw[1] <> "OK" then do
    failures = failures + 1
    say "bad first status" raw[1]
  end

  if a <> "5" | message <> "done 5" then do
    failures = failures + 1
    say "bad first expose" a message
  end
  if out[0] <> 2 | out[1] <> "script starting" | out[2] <> "1" then do
    failures = failures + 1
    say "bad first output" out[0] out[1] out[2]
  end

  do i=1 to out[0]
     say 'OUT : 'i out[i]
  end

  do i=1 to raw[0]
       say 'RAW : 'i raw[i]
    end
  say
  say "Sample 2"
  say "--------"
  REXXSCRIPT "if 0 then do; say 'bad'; end; say 'good'" OUTPUT out RESULT raw debug
  say "Status of executed script "script_status
  if raw[1] <> "OK" then do
     failures = failures + 1
     say "bad second status" raw[1]
  end
  if out[0] <> 1 | out[1] <> "good" then do
    failures = failures + 1
    say "bad second output" out[0] out[1]
  end

  if failures = 0 then say "SUCCESS"
  else say "FAILURES" failures

 status='undefined'
 say
 say "Sample 3"
 say "--------"
 REXXSCRIPT "status='is OK'; if 0 then do; say 'is bad'; status='is BAD'; end; say status" expose status output out debug
  say "Status of executed script "script_status
   return
