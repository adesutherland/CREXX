options levelb
import rxcptest
import rxcpexits
import rxcp

main: procedure
  failures = .int
  failures = 0

  failures = failures + test_descriptor()
  failures = failures + test_modes()
  failures = failures + test_value_option()
  failures = failures + test_output_options()
  failures = failures + test_pre_process_keywords()
  failures = failures + test_errors()

  call report_result failures
  return

test_descriptor: procedure = .int
  failures = .int
  tx = .traceexit(3000)
  desc = .exitdescriptor
  failures = 0

  desc = tx.describe()
  if check_equal("trace protocol version", "2", desc.get_protocol_version()) = 0 then failures = failures + 1
  if check_true("trace certified flag", descriptor_has_flag(desc, "certified") > 0, "missing certified flag") = 0 then failures = failures + 1
  if check_true("trace reserved flag", descriptor_has_flag(desc, "reserved_keyword") > 0, "missing reserved flag") = 0 then failures = failures + 1
  if check_true("trace rxfnsb import", find_descriptor_import(desc, "rxfnsb") > 0, "missing rxfnsb import") = 0 then failures = failures + 1

  return failures

test_modes: procedure = .int
  failures = .int
  tx = .traceexit(3001)
  result = .exitresult
  failures = 0

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "normal"
  result = tx.process(tokens)
  if check_equal("trace normal process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace normal mode", replacement, 'call _trace_set("N")') = 0 then failures = failures + 1
  if check_contains("trace normal current mode", replacement, '_trace_current_mode()') = 0 then failures = failures + 1
  if check_contains("trace normal bpoff", replacement, 'assembler bpoff') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "asm"
  result = tx.process(tokens)
  if check_equal("trace asm process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace asm mode", replacement, 'call _trace_set("ASM")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "all"
  result = tx.process(tokens)
  if check_equal("trace all process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace all mode", replacement, 'call _trace_set("A")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "r"
  result = tx.process(tokens)
  if check_equal("trace r process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace r mode", replacement, 'call _trace_set("R")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "re"
  result = tx.process(tokens)
  if check_equal("trace re process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace re mode", replacement, 'call _trace_set("R")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "res"
  result = tx.process(tokens)
  if check_equal("trace res process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace res mode", replacement, 'call _trace_set("R")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "results"
  result = tx.process(tokens)
  if check_equal("trace results process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace results mode", replacement, 'call _trace_set("R")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "env"
  result = tx.process(tokens)
  if check_equal("trace env process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace env mode", replacement, "call _trace_set_from_env(1)") = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "as"
  result = tx.process(tokens)
  if check_equal("trace as process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace as mode", replacement, 'call _trace_set("ASM")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "ll"
  result = tx.process(tokens)
  if check_equal("trace ll process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace ll mode", replacement, 'call _trace_set("LLM")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushoperator tokens, "?"
  call pushidentifier tokens, "r"
  result = tx.process(tokens)
  if check_equal("trace ?r process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace ?r mode", replacement, 'call _trace_set("R")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "llm"
  result = tx.process(tokens)
  if check_equal("trace llm process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace llm mode", replacement, 'call _trace_set("LLM")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "off"
  result = tx.process(tokens)
  if check_equal("trace off process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace off mode", replacement, 'call _trace_set("OFF")') = 0 then failures = failures + 1
  if check_contains("trace off bpoff", replacement, 'assembler bpoff') = 0 then failures = failures + 1

  return failures

test_value_option: procedure = .int
  failures = .int
  tx = .traceexit(3004)
  result = .exitresult
  failures = 0

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "VALUE"
  call pushidentifier tokens, "setting"
  result = tx.process(tokens)
  if check_equal("trace value process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace value normalizes", replacement, "call _trace_set(_trace_mode_from_option(setting))") = 0 then failures = failures + 1
  if check_contains("trace value current mode", replacement, "__rxtrace_mode=_trace_current_mode()") = 0 then failures = failures + 1

  return failures

test_output_options: procedure = .int
  failures = .int
  tx = .traceexit(3005)
  result = .exitresult
  failures = 0

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "rexx"
  call pushidentifier tokens, "to"
  call pushidentifier tokens, "stderr"
  result = tx.process(tokens)
  if check_equal("trace stderr process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace stderr output", replacement, 'call _trace_set_output("stderr")') = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "env"
  call pushidentifier tokens, "TO"
  call pushidentifier tokens, "STDERR"
  result = tx.process(tokens)
  if check_equal("trace env stderr process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace env stderr output", replacement, 'call _trace_set_output("stderr")') = 0 then failures = failures + 1
  if check_contains("trace env stderr mode", replacement, "call _trace_set_from_env(0)") = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "llm"
  call pushidentifier tokens, "to"
  call pushidentifier tokens, "file"
  call pushidentifier tokens, "trace_file"
  result = tx.process(tokens)
  if check_equal("trace file process", "REPLACE", result.get_status()) = 0 then failures = failures + 1
  replacement = join_result_lines(result)
  if check_contains("trace file output", replacement, "call _trace_set_output(trace_file)") = 0 then failures = failures + 1
  if check_contains("trace file llm", replacement, 'call _trace_set("LLM")') = 0 then failures = failures + 1

  return failures

test_pre_process_keywords: procedure = .int
  failures = .int
  tx = .traceexit(3002)
  plan = .exitplan
  failures = 0

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "rexx"

  plan = tx.pre_process(tokens)
  if check_equal("trace pre_process", "READY", plan.get_status()) = 0 then failures = failures + 1
  if check_true("trace keyword claim", find_keyword(plan, "rexx") > 0, "missing trace option keyword") = 0 then failures = failures + 1
  if check_equal("trace helper count", "1", plan.get_helper_count()) = 0 then failures = failures + 1
  if plan.get_helper_count() > 0 then do
    helper = plan.get_helper(1)
    helper_text = ""
    do i = 1 to helper.get_line_count()
      helper_text = helper_text || helper.get_line(i)
    end
    if check_contains("trace helper delegates", helper_text, "_trace_handler(__rxtrace_raw)") = 0 then failures = failures + 1
  end

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "normal"

  plan = tx.pre_process(tokens)
  if check_equal("trace normal pre_process", "READY", plan.get_status()) = 0 then failures = failures + 1
  if check_equal("trace normal helper count", "1", plan.get_helper_count()) = 0 then failures = failures + 1

  return failures

test_errors: procedure = .int
  failures = .int
  tx = .traceexit(3003)
  result = .exitresult
  failures = 0

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  result = tx.process(tokens)
  if check_equal("trace missing option status", "ERROR", result.get_status()) = 0 then failures = failures + 1

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "potato"
  result = tx.process(tokens)
  if check_equal("trace unknown option status", "ERROR", result.get_status()) = 0 then failures = failures + 1
  if result.get_diagnostic_count() > 0 then do
    diagnostic = result.get_diagnostic(1)
    if check_equal("trace unknown option code", "TRACE_UNKNOWN_OPTION", diagnostic.get_code()) = 0 then failures = failures + 1
  end

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "ras"
  result = tx.process(tokens)
  if check_equal("trace invalid result-prefix status", "ERROR", result.get_status()) = 0 then failures = failures + 1
  if result.get_diagnostic_count() > 0 then do
    diagnostic = result.get_diagnostic(1)
    if check_equal("trace invalid result-prefix code", "TRACE_UNKNOWN_OPTION", diagnostic.get_code()) = 0 then failures = failures + 1
  end

  tokens = newtokens()
  call pushexitkeyword tokens, "TRACE"
  call pushidentifier tokens, "rexx"
  call pushidentifier tokens, "extra"
  result = tx.process(tokens)
  if check_equal("trace extra operand status", "ERROR", result.get_status()) = 0 then failures = failures + 1

  return failures
