options levelb
namespace rxcpexits expose traceexit

import rxcp
import rxfnsb

traceexit: class
    _id = .int
    _helper_added = .int

    *: factory
        arg id = 0
        _id = id
        _helper_added = 0
        return

    describe: method = .exitdescriptor
        desc = .exitdescriptor("TRACE")
        call desc.add_flag("certified")
        call desc.add_flag("reserved_keyword")
        call desc.add_import("rxfnsb", "trace", "")
        return desc

    pre_process: method = .exitplan
        arg tokens = .token[]
        plan = .exitplan("READY")
        start = firstPayloadToken(tokens)
        if start > 0 & start <= tokens.0 then do
            to_index = findTraceOutputClause(tokens, start)
            limit = tokens.0
            if to_index > 0 then limit = to_index - 1
            if isTraceNamespaceControl(tokens, start, limit) <> 0 then do
                call plan.add_keyword(start, tokens[start].get_text(), "trace_option", "trace")
            end
            else if upper(strip(tokens[start].get_text())) = "VALUE" then do
                call plan.add_keyword(start, tokens[start].get_text(), "trace_option", "trace")
                if _helper_added = 0 then do
                    call addTraceHelpers plan
                    _helper_added = 1
                end
            end
            else do
                mode_end = 0
                mode_text = staticTraceModeText(tokens, start, limit, mode_end)
                mode = canonicalTraceMode(mode_text)
                if mode <> "" then do
                    call plan.add_keyword(start, tokens[start].get_text(), "trace_option", "trace")
                    if _helper_added = 0 then do
                        call addTraceHelpers plan
                        _helper_added = 1
                    end
                end
            end
        end
        return plan

    process: method = .exitresult
        arg tokens = .token[]
        start = firstPayloadToken(tokens)
        if start = 0 then return error_result(1, "TRACE_REQUIRES_OPTION")

        to_index = findTraceOutputClause(tokens, start)
        limit = tokens.0
        if to_index > 0 then limit = to_index - 1

        if isTraceNamespaceControl(tokens, start, limit) <> 0 then do
            if to_index > 0 then return error_result(to_index, "TRACE_NAMESPACE_CONTROL_HAS_NO_OUTPUT")
            return traceNamespaceControl(tokens, start, limit)
        end

        result = .exitresult("REPLACE")
        output_is_explicit = 0
        if to_index > 0 then do
            error_token = 0
            output_expr = traceOutputExpression(tokens, to_index, error_token)
            if output_expr = "" then return error_result(error_token, "TRACE_OUTPUT_REQUIRES_TARGET")
            output_is_explicit = 1
            call result.add_replacement_line("call _trace_set_output(" || output_expr || ")")
        end

        if upper(strip(tokens[start].get_text())) = "VALUE" then do
            if start + 1 > limit then return error_result(start, "TRACE_VALUE_REQUIRES_EXPRESSION")
            mode_expr = joinTokenText(tokens, start + 1, limit)
            call result.add_replacement_line("call _trace_set(_trace_mode_from_option(" || mode_expr || "))")
            call addTraceActivation result
            return result
        end

        mode_end = 0
        mode_text = staticTraceModeText(tokens, start, limit, mode_end)
        if mode_text = "" then return error_result(start, "TRACE_REQUIRES_OPTION")
        if mode_end <> limit then return error_result(mode_end + 1, "TRACE_UNEXPECTED_OPERAND")

        mode = canonicalTraceMode(mode_text)
        if mode = "" then return error_result(start, "TRACE_UNKNOWN_OPTION")

        if mode = "OFF" then call result.add_replacement_line("assembler bpoff")
        if mode = "ENV" then call result.add_replacement_line("call _trace_set_from_env(" || (1 - output_is_explicit) || ")")
        else call result.add_replacement_line("call _trace_set(""" || mode || """)")
        call addTraceActivation result
        return result

firstPayloadToken: procedure = .int
    arg tokens = .token[]
    if tokens.0 < 1 then return 0
    if upper(tokens[1].get_text()) = "TRACE" then do
        if tokens.0 < 2 then return 0
        return 2
    end
    return 1

findTraceOutputClause: procedure = .int
    arg tokens = .token[], start = .int
    do i = start + 1 to tokens.0
        if upper(strip(tokens[i].get_text())) = "TO" then return i
    end
    return 0

isTraceNamespaceControl: procedure = .int
    arg tokens = .token[], start = .int, limit = .int
    if start > limit then return 0
    word = upper(strip(tokens[start].get_text()))
    if word = "SUPPRESS" then return 1
    if word = "UNSUPPRESS" then return 1
    if word = "RESET" then return 1
    if word = "ADD" then return 1
    if word = "REMOVE" then return 1
    return 0

traceNamespaceControl: procedure = .exitresult
    arg tokens = .token[], start = .int, limit = .int
    result = .exitresult("REPLACE")
    word = upper(strip(tokens[start].get_text()))

    if word = "RESET" then do
        if start + 1 > limit then return error_result(start, "TRACE_RESET_REQUIRES_NAMESPACES")
        subject = upper(strip(tokens[start + 1].get_text()))
        if subject \= "NAMESPACE" & subject \= "NAMESPACES" then return error_result(start + 1, "TRACE_RESET_REQUIRES_NAMESPACES")
        if start + 1 \= limit then return error_result(start + 2, "TRACE_UNEXPECTED_OPERAND")
        call result.add_replacement_line("call _trace_reset_namespace_filters()")
        return result
    end

    if word = "SUPPRESS" then return traceNamespaceSet(result, tokens, start + 1, limit, "_trace_suppress_namespace", "TRACE_SUPPRESS_REQUIRES_NAMESPACE")
    if word = "UNSUPPRESS" then return traceNamespaceSet(result, tokens, start + 1, limit, "_trace_unsuppress_namespace", "TRACE_UNSUPPRESS_REQUIRES_NAMESPACE")

    if word = "ADD" then do
        if start + 1 > limit then return error_result(start, "TRACE_ADD_REQUIRES_SUPPRESSED")
        if upper(strip(tokens[start + 1].get_text())) \= "SUPPRESSED" then return error_result(start + 1, "TRACE_ADD_REQUIRES_SUPPRESSED")
        return traceNamespaceSet(result, tokens, start + 2, limit, "_trace_suppress_namespace", "TRACE_SUPPRESS_REQUIRES_NAMESPACE")
    end

    if word = "REMOVE" then do
        if start + 1 > limit then return error_result(start, "TRACE_REMOVE_REQUIRES_SUPPRESSED")
        if upper(strip(tokens[start + 1].get_text())) \= "SUPPRESSED" then return error_result(start + 1, "TRACE_REMOVE_REQUIRES_SUPPRESSED")
        return traceNamespaceSet(result, tokens, start + 2, limit, "_trace_unsuppress_namespace", "TRACE_UNSUPPRESS_REQUIRES_NAMESPACE")
    end

    return error_result(start, "TRACE_UNKNOWN_OPTION")

traceNamespaceSet: procedure = .exitresult
    arg result = .exitresult, tokens = .token[], namespace_token = .int, limit = .int, helper_name = .string, error_code = .string
    if namespace_token > limit then return error_result(namespace_token - 1, error_code)
    subject = upper(strip(tokens[namespace_token].get_text()))
    if subject \= "NAMESPACE" & subject \= "NAMESPACES" then return error_result(namespace_token, error_code)
    name_token = namespace_token + 1
    if name_token > limit then return error_result(namespace_token, "TRACE_NAMESPACE_REQUIRES_NAME")
    if name_token \= limit then return error_result(name_token + 1, "TRACE_UNEXPECTED_OPERAND")
    call result.add_replacement_line("call " || helper_name || "(" || traceNamespaceArgument(tokens[name_token]) || ")")
    return result

traceNamespaceArgument: procedure = .string
    arg tok = .token
    if strip(tok.get_type()) = "string_literal" then return tok.get_text()
    return quoteTraceString(tok.get_text())

quoteTraceString: procedure = .string
    arg raw = .string
    quoted = "'"
    do i = 1 to length(raw)
        ch = substr(raw, i, 1)
        if ch = "'" then quoted = quoted || "''"
        else quoted = quoted || ch
    end
    return quoted || "'"

staticTraceModeText: procedure = .string
    arg tokens = .token[], start = .int, limit = .int, expose mode_end = .int
    if start > limit then return ""
    text = strip(tokens[start].get_text())
    mode_end = start

    if text = "?" then do
        if start = limit then return "?"
        mode_end = start + 1
        return "?" || strip(tokens[mode_end].get_text())
    end

    if (text = "+" | text = "-") & start < limit then do
        mode_end = start + 1
        return text || strip(tokens[mode_end].get_text())
    end

    return text

canonicalTraceMode: procedure = .string
    arg text = .string
    mode = upper(strip(text))
    do while left(mode, 1) = "?"
        mode = substr(mode, 2)
    end
    if mode = "" then return "REXX"
    if isSignedInteger(mode) <> 0 then do
        if mode + 0 = 0 then return "OFF"
        return "N"
    end
    if mode = "ENV" then return "ENV"
    if mode = "REXX" then return "REXX"
    if traceOptionPrefix(mode, "ASM", 2) <> 0 then return "ASM"
    if traceOptionPrefix(mode, "LLM", 2) <> 0 then return "LLM"
    if mode = "JSON" then return "LLM"
    if mode = "META" then return "LLM"
    if mode = "METADATA" then return "LLM"
    if traceOptionPrefix(mode, "ALL", 1) <> 0 then return "A"
    if traceOptionPrefix(mode, "COMMAND", 1) <> 0 then return "C"
    if traceOptionPrefix(mode, "COMMANDS", 1) <> 0 then return "C"
    if traceOptionPrefix(mode, "ERROR", 1) <> 0 then return "E"
    if traceOptionPrefix(mode, "ERRORS", 1) <> 0 then return "E"
    if traceOptionPrefix(mode, "FAILURE", 1) <> 0 then return "F"
    if traceOptionPrefix(mode, "FAILURES", 1) <> 0 then return "F"
    if traceOptionPrefix(mode, "INTERMEDIATE", 1) <> 0 then return "I"
    if traceOptionPrefix(mode, "INTERMEDIATES", 1) <> 0 then return "I"
    if traceOptionPrefix(mode, "LABEL", 1) <> 0 then return "L"
    if traceOptionPrefix(mode, "LABELS", 1) <> 0 then return "L"
    if traceOptionPrefix(mode, "NORMAL", 1) <> 0 then return "N"
    if traceOptionPrefix(mode, "OFF", 1) <> 0 then return "OFF"
    if traceOptionPrefix(mode, "RESULT", 1) <> 0 then return "R"
    if traceOptionPrefix(mode, "RESULTS", 1) <> 0 then return "R"
    return ""

traceOptionPrefix: procedure = .int
    arg option = .string, word = .string, minimum = .int
    option = upper(strip(option))
    word = upper(strip(word))
    if length(option) < minimum then return 0
    if length(option) > length(word) then return 0
    if left(word, length(option)) = option then return 1
    return 0

traceNeedsBreakpoints: procedure = .int
    arg mode = .string
    mode = upper(strip(mode))
    if mode = "ASM" then return 1
    if mode = "LLM" then return 1
    if mode = "A" then return 1
    if mode = "I" then return 1
    if mode = "R" then return 1
    if mode = "REXX" then return 1
    return 0

isSignedInteger: procedure = .int
    arg text = .string
    if text = "" then return 0
    if left(text, 1) = "+" | left(text, 1) = "-" then text = substr(text, 2)
    if text = "" then return 0
    do i = 1 to length(text)
        if pos(substr(text, i, 1), "0123456789") = 0 then return 0
    end
    return 1

traceOutputExpression: procedure = .string
    arg tokens = .token[], to_index = .int, expose error_token = .int
    error_token = to_index
    if to_index >= tokens.0 then return ""

    target_token = to_index + 1
    target = upper(strip(tokens[target_token].get_text()))
    if target = "STDOUT" then return """stdout"""
    if target = "OUT" then return """stdout"""
    if target = "OUTPUT" then return """stdout"""
    if target = "STDERR" then return """stderr"""
    if target = "ERR" then return """stderr"""
    if target = "ERROR" then return """stderr"""

    if target = "FILE" then do
        if target_token >= tokens.0 then do
            error_token = target_token
            return ""
        end
        error_token = 0
        return joinTokenText(tokens, target_token + 1, tokens.0)
    end

    error_token = 0
    return joinTokenText(tokens, target_token, tokens.0)

joinTokenText: procedure = .string
    arg tokens = .token[], first = .int, last = .int
    result = ""
    if first > last then return result
    do i = first to last
        if result <> "" then result = result || " "
        result = result || tokens[i].get_text()
    end
    return result

addTraceActivation: procedure = .void
    arg result = .exitresult
    call result.add_replacement_line("__rxtrace_mode=_trace_current_mode()")
    call result.add_replacement_line("call __rxtrace_reset_display_state()")
    call result.add_replacement_line("if __rxtrace_mode = ""OFF"" then assembler bpoff")
    call result.add_replacement_line("else if _trace_needs_breakpoints(__rxtrace_mode) = 0 then assembler bpoff")
    call result.add_replacement_line("else do")
    call result.add_replacement_line("  assembler sigcall __rxtrace_handler(),""BREAKPOINT""")
    call result.add_replacement_line("  assembler bpon")
    call result.add_replacement_line("end")
    return

addTraceHelpers: procedure = .void
    arg plan = .exitplan
    call plan.add_helper(makeTraceHelper())
    call plan.add_helper(makeTraceResetHelper())
    return

makeTraceHelper: procedure = .helperplan
    helper = .helperplan("__rxtrace_handler", "file_tail", "__rxtrace_handler", "")
    call helper.add_line('__rxtrace_handler: procedure = .int expose __rxtrace_in_handler __rxtrace_first_source_file __rxtrace_last_source_file')
    call helper.add_line('  arg expose __rxtrace_raw = .trace_interrupt_raw')
    call helper.add_line('  if __rxtrace_in_handler <> 0 then return 0')
    call helper.add_line('  __rxtrace_in_handler = 1')
    call helper.add_line('  if _trace_current_mode() = "OFF" then do')
    call helper.add_line('    __rxtrace_in_handler = 0')
    call helper.add_line('    return 0')
    call helper.add_line('  end')
    call helper.add_line('  if _trace_should_trace_module(__rxtrace_raw.module()) = 0 then do')
    call helper.add_line('    __rxtrace_in_handler = 0')
    call helper.add_line('    return 0')
    call helper.add_line('  end')
    call helper.add_line('  __rxtrace_event = .tracecontext')
    call helper.add_line('  __rxtrace_event = _trace_context_from_raw(__rxtrace_raw)')
    call helper.add_line('  if _trace_should_trace_context(__rxtrace_event) = 0 then do')
    call helper.add_line('    __rxtrace_in_handler = 0')
    call helper.add_line('    return 0')
    call helper.add_line('  end')
    call helper.add_line('  __rxtrace_mode = _trace_current_mode()')
    call helper.add_line('  if _trace_needs_breakpoints(__rxtrace_mode) = 0 then do')
    call helper.add_line('    __rxtrace_in_handler = 0')
    call helper.add_line('    return 0')
    call helper.add_line('  end')
    call helper.add_line('  __rxtrace_format = _trace_current_format()')
    call helper.add_line('  __rxtrace_line = ""')
    call helper.add_line('  __rxtrace_key = ""')
    call helper.add_line('  __rxtrace_emit_source = 0')
    call helper.add_line('  __rxtrace_values_mode = 0')
    call helper.add_line('  if __rxtrace_mode = "R" then __rxtrace_values_mode = 1')
    call helper.add_line('  else if __rxtrace_mode = "I" then __rxtrace_values_mode = 1')
    call helper.add_line('  if __rxtrace_mode = "ASM" then do')
    call helper.add_line('    if __rxtrace_event.asm_line() <> "" then do')
    call helper.add_line('      __rxtrace_key = "ASM|" || __rxtrace_event.module() || "|" || __rxtrace_event.address() || "|" || __rxtrace_event.asm_line()')
    call helper.add_line('      __rxtrace_line = __rxtrace_event.asm_line()')
    call helper.add_line('      __rxtrace_emit_source = 1')
    call helper.add_line('    end')
    call helper.add_line('  end')
    call helper.add_line('  else do')
    call helper.add_line('    if __rxtrace_event.has_source() <> 0 then do')
    call helper.add_line('      __rxtrace_key = "SRC|" || __rxtrace_event.module() || "|" || __rxtrace_event.line() || "|" || __rxtrace_event.column() || "|" || __rxtrace_event.source()')
    call helper.add_line('      if __rxtrace_event.line() > 99999 then __rxtrace_prefix = "?" || right(__rxtrace_event.line(), 5, "0")')
    call helper.add_line('      else __rxtrace_prefix = right(__rxtrace_event.line(), 6, " " )')
    call helper.add_line('      __rxtrace_line = __rxtrace_prefix || " *-* " || _trace_escape_text(__rxtrace_event.source())')
    call helper.add_line('      __rxtrace_emit_source = 1')
    call helper.add_line('    end')
    call helper.add_line('  end')
    call helper.add_line('  if __rxtrace_format = "LLM" & __rxtrace_emit_source <> 0 then do')
    call helper.add_line("    __rxtrace_line = '{""event"":""trace"",""format"":""llm"",""mode"":""' || _trace_escape_text(__rxtrace_mode) || '"",""module"":""' || __rxtrace_event.module() || '"",""address"":""' || __rxtrace_event.address() || '"",""procedure"":""' || _trace_escape_text(__rxtrace_event.procedure()) || '"",""file"":""' || _trace_escape_text(__rxtrace_event.source_file()) || '"",""line"":""' || __rxtrace_event.line() || '"",""column"":""' || __rxtrace_event.column() || '"",""source"":""' || _trace_escape_text(__rxtrace_event.source()) || '"",""asm"":""' || _trace_escape_text(__rxtrace_event.asm_line()) || '""}'")
    call helper.add_line('  end')
    call helper.add_line('  if __rxtrace_format <> "LLM" then do')
    call helper.add_line('    if __rxtrace_values_mode <> 0 then do')
    call helper.add_line('      call _trace_capture_result_target(__rxtrace_event.module(), __rxtrace_event.address())')
    call helper.add_line('      __rxtrace_parent_type = ""')
    call helper.add_line('      __rxtrace_parent_value = ""')
    call helper.add_line('      __rxtrace_parent_register = _trace_pending_parent_register(__rxtrace_event.module(), __rxtrace_parent_type, __rxtrace_parent_value)')
    call helper.add_line('      if __rxtrace_parent_register = -2 then call _trace_supply_parent_value(__rxtrace_parent_value)')
    call helper.add_line('      else if __rxtrace_parent_register >= 0 then do')
    call helper.add_line('        if __rxtrace_parent_type = ".int" then do')
    call helper.add_line('          __rxtrace_i_value = 0')
    call helper.add_line('          assembler metalinkpreg __rxtrace_i_value,__rxtrace_parent_register')
    call helper.add_line('          call _trace_supply_parent_value(__rxtrace_i_value)')
    call helper.add_line('          assembler unlink __rxtrace_i_value')
    call helper.add_line('        end')
    call helper.add_line('        else if __rxtrace_parent_type = ".float" then do')
    call helper.add_line('          __rxtrace_f_value = 0.0')
    call helper.add_line('          assembler metalinkpreg __rxtrace_f_value,__rxtrace_parent_register')
    call helper.add_line('          call _trace_supply_parent_value(__rxtrace_f_value)')
    call helper.add_line('          assembler unlink __rxtrace_f_value')
    call helper.add_line('        end')
    call helper.add_line('        else do')
    call helper.add_line('          __rxtrace_s_value = ""')
    call helper.add_line('          assembler metalinkpreg __rxtrace_s_value,__rxtrace_parent_register')
    call helper.add_line('          call _trace_supply_parent_value(__rxtrace_s_value)')
    call helper.add_line('          assembler unlink __rxtrace_s_value')
    call helper.add_line('        end')
    call helper.add_line('      end')
    call helper.add_line('      if _trace_pending_result() <> 0 then do')
    call helper.add_line('        if __rxtrace_event.module() = _trace_pending_module() then do')
    call helper.add_line('          __rxtrace_pending_value = ""')
    call helper.add_line('          __rxtrace_pending_ready = 0')
    call helper.add_line('          if _trace_pending_has_const() <> 0 then do')
    call helper.add_line('            __rxtrace_pending_value = _trace_pending_const()')
    call helper.add_line('            __rxtrace_pending_ready = 1')
    call helper.add_line('          end')
    call helper.add_line('          else if _trace_supplied_result() <> 0 then do')
    call helper.add_line('            __rxtrace_pending_value = _trace_supplied_value()')
    call helper.add_line('            __rxtrace_pending_ready = 1')
    call helper.add_line('          end')
    call helper.add_line("          if __rxtrace_pending_ready <> 0 then call _trace_write_line('       ' || _trace_pending_prefix() || '   ""' || _trace_escape_text(__rxtrace_pending_value) || '""')")
    call helper.add_line('          call _trace_clear_pending_result()')
    call helper.add_line('        end')
    call helper.add_line('      end')
    call helper.add_line('    end')
    call helper.add_line('  end')
    call helper.add_line('  if __rxtrace_emit_source <> 0 then do')
    call helper.add_line('    if _trace_should_emit_key(__rxtrace_key) <> 0 then do')
    call helper.add_line('      if __rxtrace_format <> "LLM" then do')
    call helper.add_line('        __rxtrace_source_file = __rxtrace_event.source_file()')
    call helper.add_line('        if __rxtrace_source_file <> "" then do')
    call helper.add_line('          if __rxtrace_first_source_file = "" then do')
    call helper.add_line('            __rxtrace_first_source_file = __rxtrace_source_file')
    call helper.add_line('            __rxtrace_last_source_file = __rxtrace_source_file')
    call helper.add_line('          end')
    call helper.add_line('          else if __rxtrace_source_file <> __rxtrace_last_source_file then do')
    call helper.add_line('            call _trace_write_line("       >  >   " || _trace_escape_text(__rxtrace_source_file))')
    call helper.add_line('            __rxtrace_last_source_file = __rxtrace_source_file')
    call helper.add_line('          end')
    call helper.add_line('        end')
    call helper.add_line('      end')
    call helper.add_line('      call _trace_write_line(__rxtrace_line)')
    call helper.add_line('    end')
    call helper.add_line('  end')
    call helper.add_line('  __rxtrace_in_handler = 0')
    call helper.add_line('  return 0')
    return helper

makeTraceResetHelper: procedure = .helperplan
    helper = .helperplan("__rxtrace_reset_display_state", "file_tail", "__rxtrace_reset_display_state", "")
    call helper.add_line('__rxtrace_reset_display_state: procedure = .void expose __rxtrace_first_source_file __rxtrace_last_source_file')
    call helper.add_line('  __rxtrace_first_source_file = ""')
    call helper.add_line('  __rxtrace_last_source_file = ""')
    call helper.add_line('  return')
    return helper

error_result: procedure = .exitresult
    arg token_index = .int, message = .string
    result = .exitresult("ERROR")
    call result.set_error(token_index, message)
    return result
