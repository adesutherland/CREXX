.srcfile="11_scope.rexx"
.globals=0

main() .locals=3
   .meta "11_scope.main"="b" ".void" main() "" ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .src 3:1="a = 50"
   .meta "11_scope.main.a"="b" ".int" r0
   load r0,50
   .src 4:1="call Inner"
   load r1,0
   call r2,Inner(),r1
   .src 5:0="if a = 50"
   ieq r1,r0,50
   brf l17iffalse,r1
   .src 5:11="then"
   .src 5:16="say \"Outer A Preserved\""
   say "Outer A Preserved"
   br l17ifend
   .src 6:1="else"
l17iffalse:
   .src 6:6="say \"Outer A Corrupted\""
   say "Outer A Corrupted"
l17ifend:
   .src 7:1="return"
   ret
   .meta "11_scope.main.a"

Inner() .locals=2
   .meta "11_scope.inner"="b" ".void" Inner() "" ""
   .src 9:1="Inner: procedure"
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .src 10:3="a = 10"
   .meta "11_scope.inner.a"="b" ".int" r0
   load r0,10
   .src 11:3="say \"Inner A is\" a"
   itos r0
   sconcat r1,"Inner A is",r0
   say r1
   .src 12:3="return"
   ret
   .meta "11_scope.inner.a"
