.srcfile="06_logic.rexx"
.globals=0

main() .locals=4
   .meta "06_logic.main"="b" ".void" main() "" ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .src 2:1="t = 1"
   .meta "06_logic.main.t"="b" ".int" r1
   load r1,1
   .src 3:1="f = 0"
   .meta "06_logic.main.f"="b" ".int" r2
   load r2,0
   .src 4:1="say t & f"
   brf l12andfalse,r1
   icopy r3,r2
   br l12andend
l12andfalse:
   load r3,0
l12andend:
   btos r3
   say r3
   .src 5:1="say t | f"
   brt l16ortrue,r1
   icopy r3,r2
   br l16orend
l16ortrue:
   load r3,1
l16orend:
   btos r3
   say r3
   .src 6:1="say \t"
   not r3,r1
   btos r3
   say r3
   .src 6:7=""
   ret
   .meta "06_logic.main.f"
   .meta "06_logic.main.t"
