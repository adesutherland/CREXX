   unlink r1
   .src 10:1="say refBump(values[idx"
   load r0,1
   setattrs g1,3
   linkattr1 r2,g1,g0
   swap r1,r2
   call r3,refBump(),r0
   swap r2,r1
   unlink r2
   itos r3
   say r3
   .src 11:1="say values[1"
   setattrs g1,3
   linkattr1 r3,g1,1
   itos r3
   say r3
   unlink r3
   .src 12:1="say values[2"
   setattrs g1,3
   linkattr1 r3,g1,2
   itos r3
