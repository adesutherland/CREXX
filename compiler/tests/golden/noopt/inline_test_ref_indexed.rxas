refBump() .locals=1
   .meta "refidx.refbump"="b" ".int" refBump() "expose value=.int" ""
   .src 16:1="refBump: procedure = .int"
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .src 17:7="expose value = .int"
   .meta "refidx.refbump.value"="b" ".int" a1
   .src 18:3="idx = idx + 1"
   iadd g0,g0,1
   .src 19:3="value = value + 1"
   iadd a1,a1,1
   .src 20:3="return value"
   ret a1
   .meta "refidx.refbump.value"
