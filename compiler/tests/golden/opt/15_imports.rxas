.globals=0

main() .locals=2
   .meta "15_imports.main"="b" ".void" main() ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .srcstep 3 3 17 "15_imports.crexx" 6 1 15 "say myfunc(10)"
   .srcstep 2 2 17 "15_imports.crexx" 6 5 11 "say myfunc(10)"
   .srcstep 1 1 25 "mymath.crexx" 7 3 15 "  return x * x"
   load r0,100
   .traceevent "L" 4 "R" "I" "r" 0 3 3 0 "" ""
   icopy r1,r0
   br l39bexprend
l39bexprend:
   itos r1
   say r1
   .srcstep 4 4 1 "15_imports.crexx" 6 15 15 "say myfunc(10)"
   ret
