.srcfile="repro_opt_args.crexx"
.globals=0

main() .locals=0
   .meta "repro_opt_args.main"="b" ".int" main() ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .src 3:1="call test_opt 1, , 3"
   .src 10:3="say \"a=\" a \"b=\" b \"c=\" c"
   say "a= 1 b= 20 c= 3"
   .src 4:1="call test_opt 1, 2"
   .src 10:3="say \"a=\" a \"b=\" b \"c=\" c"
   say "a= 1 b= 2 c= 30"
   .src 5:1="call test_opt , 2, 3"
   .src 10:3="say \"a=\" a \"b=\" b \"c=\" c"
   say "a= 10 b= 2 c= 3"
   .src 6:1="return 0"
   ret 0
