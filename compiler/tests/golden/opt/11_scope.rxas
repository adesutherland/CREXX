.globals=0

main() .locals=0
   .meta "11_scope.main"="b" ".void" main() ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   .srcstep 2 2 17 "11_scope.crexx" 4 1 11 "call Inner"
   .srcstep 1 1 17 "11_scope.crexx" 11 3 21 "  say \"Inner A is\" a"
   say "Inner A is 10"
   .srcstep 3 3 17 "11_scope.crexx" 5 16 39 "if a = 50 then say \"Outer A Preserved\""
   .meta "11_scope.main.a"="b" ".int" "50"
   say "Outer A Preserved"
   .srcstep 4 4 17 "11_scope.crexx" 7 1 7 "return"
   ret
   .meta "11_scope.main.a"
