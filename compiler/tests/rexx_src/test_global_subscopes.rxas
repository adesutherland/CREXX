.globals=4
g0 .expose=test_global_subscopes.arr
g1 .expose=test_global_subscopes.x
g2 .expose=test_global_subscopes.y
g3 .expose=test_global_subscopes.z

main() .locals=9
   .meta "test_global_subscopes.main"="b" ".void" main() ""
   setnumdgts 18
   setnumfuz 0
   setnumfrm 1
   setnumcas 1
   setnumstd 1
   load g1,0
   load g2,0
   load g3,0
   load r0,0
   call r1,test_simple_no_subscope(),r0
   ieq r0,g2,5
   brf l49iffalse,r0
   say "test_simple_no_subscope OK"
   br l49ifend
l49iffalse:
   itos g2
   concat r2,"test_simple_no_subscope FAIL: y=",g2
   say r2
l49ifend:
   load r2,0
   call r0,test_simple(),r2
   ieq r2,g2,10
   brf l62iffalse,r2
   say "test_simple OK"
   br l62ifend
l62iffalse:
   itos g2
   concat r3,"test_simple FAIL: y=",g2
   say r3
l62ifend:
   load r3,0
   call r2,test_array(),r3
   setattrs g0,10
   linkattr1 r3,g0,1
   seq r4,r3,"changed"
   unlink r3
   brf l77iffalse,r4
   say "test_array OK"
   br l77ifend
l77iffalse:
   setattrs g0,10
   linkattr1 r5,g0,1
   concat r6,"test_array FAIL: arr[1]=",r5
   unlink r5
   say r6
l77ifend:
   load r6,0
   call r5,test_nested(),r6
   ieq r6,g1,99
   brf l90iffalse,r6
   say "test_nested OK"
   br l90ifend
l90iffalse:
   itos g1
   concat r4,"test_nested FAIL: x=",g1
   say r4
l90ifend:
   load r6,0
   call r4,test_shadowing(),r6
   ieq r6,g1,99
   brf l103iffalse,r6
   say "test_shadowing OK"
   br l103ifend
l103iffalse:
   itos g1
   concat r3,"test_shadowing FAIL: x=",g1
   say r3
l103ifend:
   setattrs g0,10
   linkattr1 r6,g0,5
   seq r3,r6,"changed again"
   unlink r6
   brf l115iffalse,r3
   say "test_shadowing (array index) OK"
   br l115ifend
l115iffalse:
   setattrs g0,10
   linkattr1 r7,g0,5
   concat r8,"test_shadowing (array index) FAIL: arr[5]=",r7
   unlink r7
   say r8
l115ifend:
   load r8,0
   call r7,test_top_level_typed(),r8
   ieq r8,g3,88
   brf l128iffalse,r8
   say "test_top_level_typed OK"
   br l128ifend
l128iffalse:
   itos g3
   concat r6,"test_top_level_typed FAIL: z=",g3
   say r6
l128ifend:
   ret

