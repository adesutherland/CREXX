options levelb
namespace reference_source_explicit expose global_counter

main: procedure = .int
  scalar = .int
  scalar_ref = reference .int

  scalar = 7
  scalar_ref = reference scalar
  if \refvalid(scalar_ref) then return fail("scalar ref invalid")
  if snapshot scalar_ref <> 7 then return fail("scalar deref initial")

  scalar = 11
  if readInt(scalar_ref) <> 11 then return fail("scalar arg live")

  scalar_snapshot = snapshot scalar_ref
  scalar = 17
  if scalar_snapshot <> 11 then return fail("scalar snapshot")
  if snapshot scalar_ref <> 17 then return fail("scalar live after snapshot")

  global_counter = .int
  global_counter = 3
  global_ref = reference .int
  global_ref = reference global_counter
  if snapshot global_ref <> 3 then return fail("global ref initial")
  call setGlobal(19)
  if readInt(global_ref) <> 19 then return fail("global ref live")

  items = .int[]
  items_ref = reference .int[]
  items[1] = 10
  items[2] = 20
  items_ref = reference items
  if \refvalid(items_ref) then return fail("array ref invalid")

  items_snapshot = snapshot items_ref
  items[1] = 30
  if items_snapshot[1] <> 10 then return fail("array snapshot")
  if firstFromArrayRef(items_ref) <> 30 then return fail("array live arg")

  box = .Box(4)
  box_ref = box.selfRef()
  if \refvalid(box_ref) then return fail("self ref invalid")
  box_snapshot = snapshot box_ref
  call box.setValue(9)
  if box_snapshot.getValue() <> 4 then return fail("self snapshot")
  if readBox(box_ref) <> 9 then return fail("self live")

  attr_ref = box.valueRef()
  if snapshot attr_ref <> 9 then return fail("attr ref initial")
  call box.setValue(12)
  if readInt(attr_ref) <> 12 then return fail("attr ref live")

  say "PASS: Reference Source Explicit"
  return 0

readInt: procedure = .int
  arg r = reference .int
  return snapshot r

firstFromArrayRef: procedure = .int
  arg r = reference .int[]
  values = snapshot r
  return values[1]

readBox: procedure = .int
  arg r = reference .Box
  box = snapshot r
  return box.getValue()

setGlobal: procedure = .void
  arg next = .int
  global_counter = next
  return

fail: procedure = .int
  arg label = .string
  say "FAIL:" label
  return 1

Box: class
  value = .int

  *: factory
    arg seed = .int
    value = seed
    return

  selfRef: method = reference .Box
    return reference self

  valueRef: method = reference .int
    return reference value

  setValue: method = .void
    arg next = .int
    value = next
    return

  getValue: method = .int
    return value
