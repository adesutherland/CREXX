options levelb

main: procedure
  out = .string[]

  address command "echo EXPLICIT_OK1"
  address path "../../bin/rxas -h" output out
  if out.1 = "cREXX Assembler" then say "EXPLICIT_OK2"
  cmd = "echo EXPLICIT_OK3"
  address cmd cmd
  address shell "echo EXPLICIT_OK4"
  address command
  address "echo EXPLICIT_OK5"
  return
