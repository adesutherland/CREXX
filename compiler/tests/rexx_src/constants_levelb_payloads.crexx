options levelb
namespace constants_levelb_payloads

constant TEXT_CONST = "hello"
constant BINARY_CONST = "41424344"x as .binary
constant BIG_BINARY_CONST = ""x as .binary
constant DECIMAL_CONST = "12.5" as .decimal
constant FLOAT_CONST = 3.25 as .float
constant INT_CONST = 0x20

data = .binary
data = BINARY_CONST
len = 0
assembler blen len,data

say "text=" || TEXT_CONST
say "bytes-len=" || len
data = BIG_BINARY_CONST
assembler blen len,data
say "big-bytes-len=" || len
say "decimal=" || (DECIMAL_CONST as .string)
say "float=" || (FLOAT_CONST as .string)
say "int=" || (INT_CONST as .string)

exit 0
