options levelb
namespace inline_test_computed_receiver_copyback

main: procedure = .int
  items = .Box[2]
  items[1] = .Box("one")
  items[2] = .Box("two")

  saved = items[pickIndex()].setAndReport("changed")
  say saved
  say items[1].getName()
  say items[2].getName()
  return 0

pickIndex: procedure = .int
  return 2

Box: class
  name = .string

  *: factory
    arg initial = .string
    name = initial
    return

  setAndReport: method = .string
    arg next = .string
    name = next
    return name

  getName: method = .string
    return name
