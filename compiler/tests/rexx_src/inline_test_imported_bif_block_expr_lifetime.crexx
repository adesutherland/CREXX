options levelb

import rxfnsb

main: procedure = .int
  p = .int
  p = skip_ws('{"ok":true,"n":12}', 11)
  say p
  if p <> 11 then return 1
  return 0

skip_ws: procedure = .int
  arg json = .string, posn = .int
  c = .string

  do while posn <= length(json)
    c = substr(json, posn, 1)
    if c = " " | c = '09'x | c = '0a'x | c = '0d'x then posn = posn + 1
    else leave
  end

  return posn
