options levelb
import rxfnsb

main: procedure = .int
  tmp = .string[]
  tmperr = .string[]
  trash = .string[]
  trasherr = .string[]
  out = .string[]
  err = .string[]

  address crexx "pid" output tmp error tmperr
  if rc \= 0 | tmp[0] = 0 then return 1
  path = "crexx-lineout-flush-visible-" || tmp[1] || ".tmp"

  address crexx "rm " || path output trash error trasherr
  payload = "payload"
  write_rc = lineout(path, payload)
  address crexx "cat " || path output out error err
  cat_rc = rc
  call lineout(path)
  address crexx "rm " || path output trash error trasherr

  say "write-rc=" || write_rc
  say "cat-rc=" || cat_rc
  say "out0=" || out[0]
  if out[0] > 0 then say "out1=" || out[1]
  say "err0=" || err[0]
  return 0
